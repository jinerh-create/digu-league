---
import BottomNav from '../components/nav/BottomNav.astro';
import '../styles/global.css';
import '../styles/typography.css';
import '../styles/components.css';

interface Props {
  title: string;
  description?: string;
  activeTab?: 'home' | 'leaderboard' | 'matches' | 'players';
}

const { title, description = 'Digu League — Gin Rummy Competition Tracker', activeTab = 'home' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head><!-- v1780757967 -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0B0F1A" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Digu" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800;900&family=Quicksand:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet" />
    <title>{title} · Digu League</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <BottomNav activeTab={activeTab} />
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </body>
</html>
