---
import BottomNav from '../components/nav/BottomNav.astro';
import '../styles/global.css';
import '../styles/typography.css';
import '../styles/components.css';

interface Props {
  title: string;
  description?: string;
  activeTab?: 'home' | 'leaderboard' | 'matches' | 'players';
}

const { title, description = 'Digu League — Gin Rummy Competition Tracker', activeTab = 'home' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#111111" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title} · Digu League</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <BottomNav activeTab={activeTab} />
  </body>
</html>
