---
/* Greatest of All Time — top 3 as FUT-style player cards on a podium.
   #1 on top, #2 & #3 below. Light-gold card, full-bleed player photo.
   Rating = GOAT score; six stat slots map the league's real metrics. */
import type { GoatRow } from '../../lib/goat';
export interface Props { board: GoatRow[]; totalTitles: number; }
const { board, totalTitles } = Astro.props;
const top3 = board.slice(0, 3);
const nick = (r: GoatRow) => r.nickname || (r.name || '').split(' ')[0] || r.name;
const photo = (r: GoatRow) => r.avatar_b64 ? `data:image/jpeg;base64,${r.avatar_b64}` : null;
const initials = (r: GoatRow) => (r.name || '').split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
const posLabel = ['GOAT', 'LGD', 'ELITE'];
const medal = ['🥇', '🥈', '🥉'];
const stats = (r: GoatRow) => [
  ['WIN', `${Math.round(r.winRate)}`], ['GME', `${Math.round(r.gamePct)}`],
  ['TTL', `${r.titles}`], ['DGU', `${r.digus}`],
  ['MCH', `${r.played}`], ['WON', `${r.won}`],
];
---
<section class="goat-card">
  <span class="goat-crest" aria-hidden="true">
    <svg viewBox="0 0 120 78" width="52" height="34">
      <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <!-- horns sweeping up & out -->
        <path d="M60 42 C 45 31 31 31 25 8" stroke-width="9" />
        <path d="M60 42 C 75 31 89 31 95 8" stroke-width="9" />
        <!-- brow / cheeks -->
        <path d="M34 47 C 42 40 52 43 60 55" stroke-width="8" />
        <path d="M86 47 C 78 40 68 43 60 55" stroke-width="8" />
        <!-- muzzle -->
        <path d="M52 56 C 53 73 67 73 68 56" stroke-width="10" />
      </g>
    </svg>
  </span>
  <div class="goat-head">
    <div>
      <h2>🐐 Greatest of All Time</h2>
      <p class="goat-sub">Live rank · titles · win rate · game % · digus</p>
    </div>
    <a href="/goat" class="goat-all">Full ranking →</a>
  </div>

  {top3.length === 0 ? (
    <div class="goat-empty">No completed matches yet — greatness is still up for grabs.</div>
  ) : (
    <>
      {(() => {
        const Card = (r: GoatRow, i: number) => (
          <a class={`fut fut-r${i}${i === 0 ? ' fut-hero' : ''}`} href={`/players/${r.playerId}`} style={`animation-delay:${i * 0.12}s`}>
            <div class="fut-frame">
              <div class="fut-in">
                <div class="fut-photo">
                  {photo(r)
                    ? <img src={photo(r)} alt={nick(r)} />
                    : <span class="fut-init">{initials(r)}</span>}
                  <div class="fut-scrim"></div>
                  <div class="fut-badge">
                    <b class="fut-rating">{Math.round(r.score)}</b>
                    <span class="fut-pos">{posLabel[i] || `#${r.rank}`}</span>
                  </div>
                  <span class="fut-medal">{medal[i]}</span>
                </div>
                <div class="fut-name">{nick(r)}</div>
                <div class="fut-stats">
                  {stats(r).map(([k, v]) => (
                    <span class="fut-stat"><b>{v}</b><small>{k}</small></span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        );
        return (
          <div class="fut-podium">
            {top3[0] && <div class="fut-top">{Card(top3[0], 0)}</div>}
            {(top3[1] || top3[2]) && (
              <div class="fut-bottom">
                {top3[1] && Card(top3[1], 1)}
                {top3[2] && Card(top3[2], 2)}
              </div>
            )}
          </div>
        );
      })()}
      <div class="goat-foot">{totalTitles} monthly {totalTitles === 1 ? 'title' : 'titles'} awarded · updates every match</div>
    </>
  )}
</section>

<style>
  .goat-card { position: relative; background: var(--card); border: 1.5px solid rgba(212,175,55,0.5); border-radius: var(--radius-lg); box-shadow: 0 0 18px rgba(212,175,55,0.12); padding: 0.95rem 0.85rem 0.8rem; margin-top: 2.8rem; margin-bottom: 1rem; }
  /* bull/GOAT crest — floats fully above the card with a gap (clear of the border) */
  .goat-crest { position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); margin-bottom: 10px; width: 66px; height: 46px; display: grid; place-items: center; background: var(--card); border: 1.5px solid rgba(212,175,55,0.6); border-radius: 14px; color: #D4AF37; box-shadow: 0 4px 14px rgba(0,0,0,.35), 0 0 12px rgba(212,175,55,.25); }
  .goat-head { display: flex; align-items: flex-start; justify-content: space-between; gap: .5rem; margin-bottom: .9rem; }
  .goat-head h2 { font-family: var(--font-heading); font-size: 1.05rem; margin: 0; color: var(--text-primary); }
  .goat-sub { font-size: .66rem; color: var(--text-muted); margin: .12rem 0 0; }
  .goat-all { font-size: .72rem; color: #D4AF37; font-weight: 700; white-space: nowrap; }
  .goat-empty { text-align: center; color: var(--text-muted); font-size: .8rem; padding: 1.6rem .5rem; }

  /* podium: #1 on top, #2 & #3 below */
  .fut-podium { display: flex; flex-direction: column; align-items: center; gap: .5rem; }
  .fut-top { width: min(128px, 38%); }
  .fut-bottom { display: flex; gap: 2.4rem; width: 100%; justify-content: center; }
  .fut-bottom .fut { width: min(122px, 35%); }

  .fut { text-decoration: none; display: block; animation: fut-in .55s cubic-bezier(.2,.8,.3,1) both; }
  @keyframes fut-in { from { opacity: 0; transform: translateY(16px) scale(.95); } }

  /* gold shield frame */
  .fut-frame {
    position: relative; padding: 2.5px;
    /* very shallow bottom notch — sides stay straight until 95% so stat text
       never meets an angled edge */
    clip-path: polygon(4% 0, 96% 0, 100% 4%, 100% 95%, 50% 100%, 0 95%, 0 4%);
    box-shadow: 0 6px 16px rgba(0,0,0,.4), inset 0 0 10px rgba(255,255,255,.25);
    transition: transform .2s;
    /* metallic band that sweeps for a shimmering border */
    background-size: 250% 100%;
    animation: fut-shimmer 3.5s linear infinite;
  }
  @keyframes fut-shimmer { to { background-position: 250% 0; } }
  .fut:hover .fut-frame { transform: translateY(-4px); }

  /* medal-tier borders */
  .fut-r0 .fut-frame { background-image: linear-gradient(115deg,#8a5f14 0%,#e9c65a 16%,#fff4c2 28%,#d4af37 44%,#8a5f14 60%,#e9c65a 78%,#fff4c2 90%,#8a5f14 100%); }
  .fut-r1 .fut-frame { background-image: linear-gradient(115deg,#6b7078 0%,#c9cfd8 16%,#ffffff 28%,#aab0b8 44%,#6b7078 60%,#c9cfd8 78%,#ffffff 90%,#6b7078 100%); animation-delay: .5s; }
  .fut-r2 .fut-frame { background-image: linear-gradient(115deg,#6e3f16 0%,#c67c3e 16%,#f2c79a 28%,#a9622c 44%,#6e3f16 60%,#c67c3e 78%,#f2c79a 90%,#6e3f16 100%); animation-delay: 1s; }

  .fut-hero .fut-frame { box-shadow: 0 8px 24px rgba(184,134,11,.35), 0 0 18px rgba(212,175,55,.3), inset 0 0 10px rgba(255,255,255,.3); }
  .fut-r1.fut .fut-frame { box-shadow: 0 6px 16px rgba(0,0,0,.4), 0 0 14px rgba(200,207,216,.28), inset 0 0 10px rgba(255,255,255,.3); }
  .fut-r2.fut .fut-frame { box-shadow: 0 6px 16px rgba(0,0,0,.4), 0 0 14px rgba(198,124,62,.3), inset 0 0 10px rgba(255,255,255,.25); }

  .fut-in {
    position: relative; overflow: hidden;
    clip-path: polygon(4% 0, 96% 0, 100% 4%, 100% 95%, 50% 100%, 0 95%, 0 4%);
    color: var(--ink);
  }
  /* metallic card bodies per rank */
  .fut-r0 .fut-in { background: linear-gradient(158deg,#fbeeb8 0%,#e6c65e 38%,#c9992b 66%,#f3dd8c 100%); --ink:#3a2c08; --ink2:#7c6019; }
  .fut-r1 .fut-in { background: linear-gradient(158deg,#f4f6f9 0%,#ccd2da 38%,#a2a9b3 66%,#e2e6ec 100%); --ink:#23272e; --ink2:#5a616b; }
  .fut-r2 .fut-in { background: linear-gradient(158deg,#f0cda4 0%,#cd8a4f 38%,#9c5a29 66%,#e0a06a 100%); --ink:#3c2410; --ink2:#7a4a24; }
  /* sweeping metallic sheen */
  .fut-in::after {
    content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 2;
    background: linear-gradient(115deg, transparent 40%, rgba(255,255,255,.6) 50%, transparent 60%);
    background-size: 300% 100%; animation: fut-sheen 3.8s linear infinite;
  }
  @keyframes fut-sheen { to { background-position: -300% 0; } }
  .fut-r1 .fut-in::after { animation-delay: .5s; }
  .fut-r2 .fut-in::after { animation-delay: 1s; }

  /* full-bleed player photo across the top — compact */
  .fut-photo { position: relative; width: 100%; height: 68px; overflow: hidden; }
  .fut-hero .fut-photo { height: 80px; }
  .fut-photo img { width: 100%; height: 100%; object-fit: cover; object-position: top center; }
  .fut-init { position: absolute; inset: 0; display: grid; place-items: center; font-family: var(--font-heading); font-weight: 800; font-size: 1.6rem; color: var(--ink); }
  /* darken only the top-left so the rating reads; let the photo meet the metal below */
  .fut-scrim { position: absolute; inset: 0; z-index: 1; background:
    linear-gradient(115deg, rgba(20,15,4,.7) 0%, rgba(20,15,4,.28) 30%, transparent 52%); }

  .fut-badge { position: absolute; top: .28rem; left: .38rem; display: flex; flex-direction: column; align-items: flex-start; z-index: 2; text-shadow: 0 1px 4px rgba(0,0,0,.8); }
  .fut-rating { font-family: var(--font-heading); font-weight: 800; font-size: 1.25rem; line-height: .82; color: #fff; }
  .fut-hero .fut-rating { font-size: 1.5rem; }
  .fut-pos { font-size: .48rem; font-weight: 800; letter-spacing: .06em; color: #ffe9b8; margin-top: .08rem; }
  .fut-medal { position: absolute; top: .24rem; right: .3rem; font-size: .78rem; z-index: 2; filter: drop-shadow(0 1px 2px rgba(0,0,0,.5)); }

  .fut-name { position: relative; z-index: 3; text-align: center; font-family: var(--font-heading); font-weight: 800; font-size: .68rem; letter-spacing: .02em; text-transform: uppercase; color: var(--ink); padding: .22rem .3rem .14rem; margin: 0 .45rem; border-bottom: 1px solid color-mix(in srgb, var(--ink) 30%, transparent); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .fut-hero .fut-name { font-size: .76rem; }

  /* extra side + bottom padding keeps every stat clear of the sloped border */
  .fut-stats { position: relative; z-index: 3; display: grid; grid-template-columns: 1fr 1fr; gap: .04rem .3rem; padding: .26rem .55rem .8rem; }
  .fut-stat { display: flex; align-items: baseline; gap: .18rem; justify-content: flex-start; }
  .fut-stat b { font-family: var(--font-heading); font-weight: 800; font-size: .68rem; color: var(--ink); font-variant-numeric: tabular-nums; min-width: 1.3ch; text-align: right; }
  .fut-hero .fut-stat b { font-size: .74rem; }
  .fut-stat small { font-size: .46rem; font-weight: 800; letter-spacing: .02em; color: var(--ink2); }

  .goat-foot { margin-top: .9rem; padding-top: .55rem; border-top: 1px solid var(--border); font-size: .64rem; color: var(--text-muted); text-align: center; }

  @media (max-width: 480px) {
    .fut-top { width: 60%; }
    .fut-bottom { gap: 1.4rem; }
    .fut-bottom .fut { width: 42%; }
    .fut-photo { height: 84px; } .fut-hero .fut-photo { height: 96px; }
  }
  @media (prefers-reduced-motion: reduce) { .fut, .fut-frame, .fut-in::after { animation: none; } .fut-in::after { display: none; } }
</style>
