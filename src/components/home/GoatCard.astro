---
/* Greatest of All Time — top 3 as FUT-style player cards on a podium.
   #1 on top, #2 & #3 below. Light-gold card, full-bleed player photo.
   Rating = GOAT score; six stat slots map the league's real metrics. */
import type { GoatRow } from '../../lib/goat';
export interface Props { board: GoatRow[]; totalTitles: number; }
const { board, totalTitles } = Astro.props;
const top3 = board.slice(0, 3);
const nick = (r: GoatRow) => r.nickname || (r.name || '').split(' ')[0] || r.name;
const photo = (r: GoatRow) => r.avatar_b64 ? `data:image/jpeg;base64,${r.avatar_b64}` : null;
const initials = (r: GoatRow) => (r.name || '').split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
const posLabel = ['GOAT', 'LGD', 'ELITE'];
const medal = ['🥇', '🥈', '🥉'];
const stats = (r: GoatRow) => [
  ['WIN', `${Math.round(r.winRate)}`], ['GME', `${Math.round(r.gamePct)}`],
  ['TTL', `${r.titles}`], ['DGU', `${r.digus}`],
  ['MCH', `${r.played}`], ['WON', `${r.won}`],
];
---
<section class="goat-card">
  <div class="goat-head">
    <div>
      <h2>🐐 Greatest of All Time</h2>
      <p class="goat-sub">Live rank · titles · win rate · game % · digus</p>
    </div>
    <a href="/goat" class="goat-all">Full ranking →</a>
  </div>

  {top3.length === 0 ? (
    <div class="goat-empty">No completed matches yet — greatness is still up for grabs.</div>
  ) : (
    <>
      {(() => {
        const Card = (r: GoatRow, i: number) => (
          <a class={`fut${i === 0 ? ' fut-hero' : ''}`} href={`/players/${r.playerId}`} style={`animation-delay:${i * 0.12}s`}>
            <div class="fut-frame">
              <div class="fut-in">
                <div class="fut-photo">
                  {photo(r)
                    ? <img src={photo(r)} alt={nick(r)} />
                    : <span class="fut-init">{initials(r)}</span>}
                  <div class="fut-scrim"></div>
                  <div class="fut-badge">
                    <b class="fut-rating">{Math.round(r.score)}</b>
                    <span class="fut-pos">{posLabel[i] || `#${r.rank}`}</span>
                  </div>
                  <span class="fut-medal">{medal[i]}</span>
                </div>
                <div class="fut-name">{nick(r)}</div>
                <div class="fut-stats">
                  {stats(r).map(([k, v]) => (
                    <span class="fut-stat"><b>{v}</b><small>{k}</small></span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        );
        return (
          <div class="fut-podium">
            {top3[0] && <div class="fut-top">{Card(top3[0], 0)}</div>}
            {(top3[1] || top3[2]) && (
              <div class="fut-bottom">
                {top3[1] && Card(top3[1], 1)}
                {top3[2] && Card(top3[2], 2)}
              </div>
            )}
          </div>
        );
      })()}
      <div class="goat-foot">{totalTitles} monthly {totalTitles === 1 ? 'title' : 'titles'} awarded · updates every match</div>
    </>
  )}
</section>

<style>
  .goat-card { background: var(--card); border: 1.5px solid rgba(212,175,55,0.5); border-radius: var(--radius-lg); box-shadow: 0 0 18px rgba(212,175,55,0.12); padding: 0.9rem 0.85rem 0.8rem; margin-bottom: 1rem; }
  .goat-head { display: flex; align-items: flex-start; justify-content: space-between; gap: .5rem; margin-bottom: .9rem; }
  .goat-head h2 { font-family: var(--font-heading); font-size: 1.05rem; margin: 0; color: var(--text-primary); }
  .goat-sub { font-size: .66rem; color: var(--text-muted); margin: .12rem 0 0; }
  .goat-all { font-size: .72rem; color: #D4AF37; font-weight: 700; white-space: nowrap; }
  .goat-empty { text-align: center; color: var(--text-muted); font-size: .8rem; padding: 1.6rem .5rem; }

  /* podium: #1 on top, #2 & #3 below */
  .fut-podium { display: flex; flex-direction: column; align-items: center; gap: .55rem; }
  .fut-top { width: min(158px, 46%); }
  .fut-bottom { display: flex; gap: .55rem; width: 100%; justify-content: center; }
  .fut-bottom .fut { width: min(150px, 42%); }

  .fut { text-decoration: none; display: block; animation: fut-in .55s cubic-bezier(.2,.8,.3,1) both; }
  @keyframes fut-in { from { opacity: 0; transform: translateY(16px) scale(.95); } }

  /* gold shield frame */
  .fut-frame {
    position: relative; padding: 2px;
    background: linear-gradient(150deg, #fbe6a6 0%, #d9b03e 28%, #a9791f 55%, #f0d477 78%, #b4841c 100%);
    /* very shallow bottom notch — sides stay straight until 95% so stat text
       never meets an angled edge */
    clip-path: polygon(4% 0, 96% 0, 100% 4%, 100% 95%, 50% 100%, 0 95%, 0 4%);
    box-shadow: 0 6px 16px rgba(0,0,0,.4), inset 0 0 10px rgba(255,255,255,.25);
    transition: transform .2s;
  }
  .fut:hover .fut-frame { transform: translateY(-4px); }
  .fut-hero .fut-frame { box-shadow: 0 8px 24px rgba(184,134,11,.35), 0 0 18px rgba(212,175,55,.3), inset 0 0 10px rgba(255,255,255,.3); }

  .fut-in {
    position: relative; overflow: hidden;
    /* dark navy + gold, matching the app theme (adapts via CSS vars) */
    background:
      linear-gradient(158deg, rgba(212,175,55,.14), transparent 42%),
      linear-gradient(158deg, var(--card-raised) 0%, var(--card) 55%, var(--surface) 100%);
    clip-path: polygon(4% 0, 96% 0, 100% 4%, 100% 95%, 50% 100%, 0 95%, 0 4%);
    color: var(--text-primary);
  }

  /* full-bleed player photo across the top — compact */
  .fut-photo { position: relative; width: 100%; height: 84px; overflow: hidden; }
  .fut-hero .fut-photo { height: 98px; }
  .fut-photo img { width: 100%; height: 100%; object-fit: cover; object-position: top center; }
  .fut-init { position: absolute; inset: 0; display: grid; place-items: center; font-family: var(--font-heading); font-weight: 800; font-size: 2rem; color: var(--gold); }
  .fut-scrim { position: absolute; inset: 0; background:
    linear-gradient(105deg, rgba(11,15,26,.72) 0%, rgba(11,15,26,.3) 32%, transparent 55%),
    linear-gradient(0deg, var(--card-raised), transparent 30%); }

  .fut-badge { position: absolute; top: .35rem; left: .45rem; display: flex; flex-direction: column; align-items: flex-start; z-index: 1; text-shadow: 0 1px 4px rgba(0,0,0,.7); }
  .fut-rating { font-family: var(--font-heading); font-weight: 800; font-size: 1.5rem; line-height: .82; color: var(--gold); }
  .fut-hero .fut-rating { font-size: 1.8rem; }
  .fut-pos { font-size: .54rem; font-weight: 800; letter-spacing: .07em; color: #ffe9a8; margin-top: .1rem; }
  .fut-medal { position: absolute; top: .3rem; right: .35rem; font-size: .9rem; z-index: 1; filter: drop-shadow(0 1px 2px rgba(0,0,0,.5)); }

  .fut-name { text-align: center; font-family: var(--font-heading); font-weight: 800; font-size: .78rem; letter-spacing: .02em; text-transform: uppercase; color: var(--gold); padding: .26rem .3rem .16rem; margin: 0 .5rem; border-bottom: 1px solid rgba(212,175,55,.3); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .fut-hero .fut-name { font-size: .88rem; }

  /* extra side + bottom padding keeps every stat clear of the sloped border */
  .fut-stats { display: grid; grid-template-columns: 1fr 1fr; gap: .05rem .4rem; padding: .32rem .75rem .95rem; }
  .fut-stat { display: flex; align-items: baseline; gap: .22rem; justify-content: flex-start; }
  .fut-stat b { font-family: var(--font-heading); font-weight: 800; font-size: .78rem; color: var(--text-primary); font-variant-numeric: tabular-nums; min-width: 1.4ch; text-align: right; }
  .fut-hero .fut-stat b { font-size: .86rem; }
  .fut-stat small { font-size: .52rem; font-weight: 800; letter-spacing: .02em; color: var(--text-muted); }

  .goat-foot { margin-top: .9rem; padding-top: .55rem; border-top: 1px solid var(--border); font-size: .64rem; color: var(--text-muted); text-align: center; }

  @media (max-width: 480px) {
    .fut-top { width: 60%; }
    .fut-bottom { gap: .4rem; }
    .fut-bottom .fut { width: 48%; }
    .fut-photo { height: 84px; } .fut-hero .fut-photo { height: 96px; }
  }
  @media (prefers-reduced-motion: reduce) { .fut { animation: none; } }
</style>
