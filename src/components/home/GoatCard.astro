---
/* Greatest of All Time — top 3 as FUT-style player cards.
   Rating = GOAT score; the six stat slots map the league's real metrics.
   Live composite of league titles, win rate, game % and digus (see lib/goat.ts). */
import type { GoatRow } from '../../lib/goat';
export interface Props { board: GoatRow[]; totalTitles: number; }
const { board, totalTitles } = Astro.props;
const top3 = board.slice(0, 3);
const nick = (r: GoatRow) => r.nickname || (r.name || '').split(' ')[0] || r.name;
const photo = (r: GoatRow) => r.avatar_b64 ? `data:image/jpeg;base64,${r.avatar_b64}` : null;
const initials = (r: GoatRow) => (r.name || '').split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
const posLabel = ['GOAT', 'LGD', 'ELITE'];
const medal = ['🥇', '🥈', '🥉'];
/* six stat slots from real DIGU metrics */
const stats = (r: GoatRow) => [
  ['WIN', `${Math.round(r.winRate)}`], ['GME', `${Math.round(r.gamePct)}`],
  ['TTL', `${r.titles}`], ['DGU', `${r.digus}`],
  ['MCH', `${r.played}`], ['WON', `${r.won}`],
];
---
<section class="goat-card">
  <div class="goat-head">
    <div>
      <h2>🐐 Greatest of All Time</h2>
      <p class="goat-sub">Live rank · titles · win rate · game % · digus</p>
    </div>
    <a href="/goat" class="goat-all">Full ranking →</a>
  </div>

  {top3.length === 0 ? (
    <div class="goat-empty">No completed matches yet — greatness is still up for grabs.</div>
  ) : (
    <>
      <div class="fut-row">
        {top3.map((r, i) => (
          <a class={`fut fut-${i}`} href={`/players/${r.playerId}`} style={`animation-delay:${i * 0.12}s`}>
            <div class="fut-frame">
              <div class="fut-in">
                <span class="fut-medal">{medal[i]}</span>
                <div class="fut-hero">
                  <div class="fut-lhs">
                    <b class="fut-rating">{Math.round(r.score)}</b>
                    <span class="fut-pos">{posLabel[i] || `#${r.rank}`}</span>
                    <span class="fut-crest">🃏</span>
                  </div>
                  <div class="fut-photo">
                    {photo(r) ? <img src={photo(r)} alt={nick(r)} /> : <span class="fut-init">{initials(r)}</span>}
                  </div>
                </div>
                <div class="fut-name">{nick(r)}</div>
                <div class="fut-stats">
                  {stats(r).map(([k, v]) => (
                    <span class="fut-stat"><b>{v}</b><small>{k}</small></span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
      <div class="goat-foot">{totalTitles} monthly {totalTitles === 1 ? 'title' : 'titles'} awarded · updates every match</div>
    </>
  )}
</section>

<style>
  .goat-card { background: var(--card); border: 1.5px solid rgba(212,175,55,0.5); border-radius: var(--radius-lg); box-shadow: 0 0 18px rgba(212,175,55,0.12); padding: 0.9rem 0.85rem 0.8rem; margin-bottom: 1rem; }
  .goat-head { display: flex; align-items: flex-start; justify-content: space-between; gap: .5rem; margin-bottom: .8rem; }
  .goat-head h2 { font-family: var(--font-heading); font-size: 1.05rem; margin: 0; color: var(--text-primary); }
  .goat-sub { font-size: .66rem; color: var(--text-muted); margin: .12rem 0 0; }
  .goat-all { font-size: .72rem; color: #D4AF37; font-weight: 700; white-space: nowrap; }
  .goat-empty { text-align: center; color: var(--text-muted); font-size: .8rem; padding: 1.6rem .5rem; }

  .fut-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: .5rem; align-items: start; }

  .fut { text-decoration: none; display: block; animation: fut-in .5s cubic-bezier(.2,.8,.3,1) both; }
  @keyframes fut-in { from { opacity: 0; transform: translateY(14px) scale(.96); } }
  .fut-1 { margin-top: .8rem; } .fut-2 { margin-top: 1.4rem; } /* podium stagger — #1 tallest */

  /* gold shield frame */
  .fut-frame {
    position: relative; padding: 2.5px;
    background: linear-gradient(150deg, #f6e27a 0%, #d4af37 30%, #b8860b 55%, #e8cf7a 80%, #b8860b 100%);
    clip-path: polygon(8% 0, 92% 0, 100% 7%, 100% 84%, 50% 100%, 0 84%, 0 7%);
    box-shadow: 0 6px 18px rgba(0,0,0,.35);
    transition: transform .18s;
  }
  .fut:hover .fut-frame { transform: translateY(-4px); }
  .fut-in {
    position: relative;
    background: linear-gradient(155deg, #fbf9f1 0%, #ffffff 42%, #efe9d8 100%);
    clip-path: polygon(8% 0, 92% 0, 100% 7%, 100% 84%, 50% 100%, 0 84%, 0 7%);
    padding: .7rem .5rem 1.5rem;
    color: #4a3d18;
  }
  .fut-medal { position: absolute; top: .3rem; right: .45rem; font-size: .95rem; filter: drop-shadow(0 1px 2px rgba(0,0,0,.3)); }

  .fut-hero { display: flex; gap: .2rem; align-items: flex-start; }
  .fut-lhs { display: flex; flex-direction: column; align-items: center; padding-top: .3rem; width: 34%; }
  .fut-rating { font-family: var(--font-heading); font-weight: 800; font-size: 1.7rem; line-height: .9; color: #3a2f12; }
  .fut-pos { font-size: .56rem; font-weight: 800; letter-spacing: .04em; color: #6b5a25; margin-top: .1rem; }
  .fut-crest { font-size: .85rem; margin-top: .2rem; opacity: .8; }
  .fut-photo { flex: 1; height: 66px; display: grid; place-items: end center; overflow: hidden; }
  .fut-photo img { height: 78px; width: auto; max-width: 100%; object-fit: cover; object-position: top center; filter: drop-shadow(0 3px 4px rgba(0,0,0,.2)); margin-bottom: -6px; }
  .fut-init { font-family: var(--font-heading); font-weight: 800; font-size: 1.7rem; color: #b8860b; align-self: center; }

  .fut-name { text-align: center; font-family: var(--font-heading); font-weight: 800; font-size: .82rem; letter-spacing: .02em; text-transform: uppercase; color: #3a2f12; border-top: 1.5px solid rgba(184,134,11,.4); margin: .25rem .3rem 0; padding-top: .25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .fut-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 0 .35rem; padding: .3rem .35rem 0; }
  .fut-stat { display: flex; align-items: baseline; gap: .22rem; justify-content: center; }
  .fut-stat b { font-family: var(--font-heading); font-weight: 800; font-size: .82rem; color: #3a2f12; font-variant-numeric: tabular-nums; }
  .fut-stat small { font-size: .56rem; font-weight: 700; color: #7a6a32; }

  .goat-foot { margin-top: .8rem; padding-top: .55rem; border-top: 1px solid var(--border); font-size: .64rem; color: var(--text-muted); text-align: center; }

  @media (max-width: 420px) {
    .fut-rating { font-size: 1.4rem; }
    .fut-photo img { height: 66px; }
    .fut-name { font-size: .72rem; }
    .fut-stat b { font-size: .74rem; }
  }
  @media (prefers-reduced-motion: reduce) { .fut { animation: none; } }
</style>
