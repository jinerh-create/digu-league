---
export const prerender = false;
const next = Astro.url.searchParams.get('next') ?? '/';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#080C14" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="icon" type="image/png" href="/icon.png" />
  <link rel="apple-touch-icon" href="/icon.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;600;700&family=Josefin+Sans:wght@300;400;600;700&family=Cormorant+Garamond:ital,wght@0,600;1,400&family=Yeseva+One&family=Italiana&display=swap" rel="stylesheet" />
  <title>Digu League · Sign In</title>
</head>
<body>

<!-- Background -->
<div class="bg"></div>
<div class="bg-blob bg-blob-1"></div>
<div class="bg-blob bg-blob-2"></div>
<canvas id="particles"></canvas>

<!-- ── MAIN SPLIT CARD ── -->
<div class="page">
  <div class="split-card">

    <!-- ══ LEFT PANEL ══ -->
    <div class="left-panel">
      <!-- Floating card suits orbiting trophy -->
      <div class="card-orbit">
        <span class="co-card co1">♠</span>
        <span class="co-card co2">♥</span>
        <span class="co-card co3">♣</span>
        <span class="co-card co4">♦</span>
        <span class="co-card co5">A</span>
        <span class="co-card co6">K</span>
        <span class="co-card co7">♠</span>
        <span class="co-card co8">♥</span>
      </div>

      <!-- Logo top left -->
      <div class="lp-logo">
        <img src="/dl-logo-v2.png" alt="Digu League" class="lp-logo-img" />
        <div class="lp-logo-text">
          <div class="lp-name">Digu League</div>
          <div class="lp-sub">One League · One Crown · One Champion</div>
        </div>
      </div>

      <!-- Trophy center -->
      <div class="lp-trophy">
        <div class="trophy-glow-ring"></div>
        <div class="trophy-glow-floor"></div>

        <!-- Card suit loader (shows briefly while image loads) -->
        <div class="suit-loader" id="suit-loader">
          <span class="sl-suit sl-s1">♠</span>
          <span class="sl-suit sl-s2">♥</span>
          <span class="sl-suit sl-s3">♣</span>
          <span class="sl-suit sl-s4">♦</span>
        </div>

        <!-- Transparent PNG trophy - no bg removal needed -->
        <div class="trophy-canvas-wrap">
          <img
            src="/trophy.png"
            alt="Digu League Trophy"
            class="trophy-canvas"
            id="trophy-img"
            style="display:none"
            onload="this.style.display='block';document.getElementById('suit-loader').style.display='none'"
          />
        </div>

        <div class="trophy-league-name">
          <span class="tln-suit">♠</span>
          DIGU LEAGUE
          <span class="tln-suit">♠</span>
        </div>
      </div>

      <!-- Bottom suits decoration -->
      <div class="lp-suits">
        <span class="s-black">♠</span>
        <span class="s-red">♥</span>
        <span class="s-black">♣</span>
        <span class="s-red">♦</span>
      </div>
    </div>

    <!-- ══ RIGHT PANEL ══ -->
    <div class="right-panel">
      <div class="rp-inner">

        <!-- Header -->
        <div class="rp-header">
          <canvas id="icon-canvas" class="rp-crown-icon"></canvas><img src="/dl-logo-v2.png" id="icon-src" style="display:none" onload="processIcon(this)">
          <h1 class="rp-title">Sign In</h1>
          <p class="rp-sub">Welcome back to the league</p>
        </div>

        <!-- OAuth error banner -->
        <p class="rp-oauth-err" id="oauth-err" style="display:none"></p>

        <!-- Role selector -->
        <div class="rp-tabs">
          <button type="button" class="rp-tab rp-tab-active" id="tab-player" onclick="switchTab('player')">
            <span class="rp-tab-icon">🎴</span> Player
          </button>
          <button type="button" class="rp-tab" id="tab-admin" onclick="switchTab('admin')">
            <span class="rp-tab-icon">⚔️</span> Admin
          </button>
        </div>

        <!-- Player form -->
        <div id="panel-player">
          <div class="rp-hint">
            <div class="rp-hint-dot"></div>
            <span>Start matches · Enter scores · Edit rounds</span>
          </div>
          <form id="player-form" onsubmit="return false">
            <input type="hidden" class="nxt" id="nxt-player" value={next} />
            <div class="rp-field">
              <label class="rp-label">Player Password</label>
              <div class="rp-iw" id="iw-player">
                <span class="rp-iw-icon">🔑</span>
                <input type="password" id="player-pw" class="rp-input"
                  placeholder="Enter password"
                  autocomplete="current-password"
                  onfocus="document.getElementById('iw-player').classList.add('rp-iw-focus')"
                  onblur="document.getElementById('iw-player').classList.remove('rp-iw-focus')" />
                <button type="button" class="rp-eye" onclick="togglePw('player-pw')">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>
            </div>
            <p class="rp-err" id="player-err"></p>
            <button type="button" class="rp-btn rp-gold-btn" id="player-sub" onclick="doLogin('player-pw','player-err','player-sub','nxt-player')">
              Sign In as Player →
            </button>
          </form>
        </div>

        <!-- Google sign-in (allow-listed emails → admin) -->
        <div class="rp-or"><span>or</span></div>
        <a href="/api/auth/google" class="rp-google-btn">
          <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/><path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/><path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 35.091 26.715 36 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303c-.792 2.237-2.231 4.166-4.087 5.571.001-.001.002-.001.003-.002l6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/></svg>
          <span>Continue with Google</span>
        </a>

        <!-- Admin form -->
        <div id="panel-admin" style="display:none">
          <div class="rp-hint rp-hint-red">
            <div class="rp-hint-dot rp-hint-dot-red"></div>
            <span>Full access · Manage players · Settings</span>
          </div>
          <form id="admin-form" onsubmit="return false">
            <input type="hidden" class="nxt" id="nxt-admin" value={next} />
            <div class="rp-field">
              <label class="rp-label">Admin Password</label>
              <div class="rp-iw" id="iw-admin">
                <span class="rp-iw-icon">🔐</span>
                <input type="password" id="admin-pw" class="rp-input"
                  placeholder="Enter password"
                  autocomplete="current-password"
                  onfocus="document.getElementById('iw-admin').classList.add('rp-iw-focus')"
                  onblur="document.getElementById('iw-admin').classList.remove('rp-iw-focus')" />
                <button type="button" class="rp-eye" onclick="togglePw('admin-pw')">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>
            </div>
            <p class="rp-err" id="admin-err"></p>
            <button type="button" class="rp-btn rp-ember-btn" id="admin-sub" onclick="doLogin('admin-pw','admin-err','admin-sub','nxt-admin')">
              Sign In as Admin →
            </button>
          </form>
        </div>

        
      </div>
    </div>

  </div>
</div>

<script is:inline>
  // Show a friendly banner if Google sign-in redirected back with ?err=
  (function () {
    var params = new URLSearchParams(window.location.search);
    var err = params.get('err');
    if (!err) return;
    var msgs = {
      not_authorized: 'That Google account is not authorized for this league.',
      not_configured: 'Google sign-in is not configured yet.',
      google_denied: 'Google sign-in was cancelled.',
      invalid_state: 'Session expired — please try Google sign-in again.',
      token_exchange: 'Could not complete Google sign-in. Try again.',
      no_email: 'Could not read your Google email. Try again.'
    };
    var el = document.getElementById('oauth-err');
    if (el) { el.textContent = msgs[err] || 'Google sign-in failed. Try again.'; el.style.display = 'block'; }
  })();

  function processIcon(img) {
    var canvas = document.getElementById('icon-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    canvas.width = img.naturalWidth;
    canvas.height = img.naturalHeight;
    ctx.drawImage(img, 0, 0);
    var data = ctx.getImageData(0, 0, canvas.width, canvas.height);
    var d = data.data;
    for (var i = 0; i < d.length; i += 4) {
      var r = d[i], g = d[i+1], b = d[i+2];
      var bright = (r + g + b) / 3;
      var sat = Math.max(r,g,b) - Math.min(r,g,b);
      if (bright > 200 && sat < 50) {
        d[i+3] = Math.max(0, 255 - (bright - 200) * 12);
      }
    }
    ctx.putImageData(data, 0, 0);
  }

  function switchTab(role) {
    var isPlayer = role === 'player';
    document.getElementById('panel-player').style.display = isPlayer ? 'block' : 'none';
    document.getElementById('panel-admin').style.display = isPlayer ? 'none' : 'block';
    document.getElementById('tab-player').className = 'rp-tab' + (isPlayer ? ' rp-tab-active' : '');
    document.getElementById('tab-admin').className = 'rp-tab' + (!isPlayer ? ' rp-tab-active rp-tab-admin-active' : '');
    // Always clear passwords when switching tabs
    document.getElementById('player-pw').value = '';
    document.getElementById('admin-pw').value = '';
    document.getElementById('player-err').textContent = '';
    document.getElementById('admin-err').textContent = '';
    // Reset input types to password
    document.getElementById('player-pw').type = 'password';
    document.getElementById('admin-pw').type = 'password';
  }

  function togglePw(inputId) {
    var input = document.getElementById(inputId);
    if (!input) return;
    input.type = input.type === 'password' ? 'text' : 'password';
  }

  function doLogin(pwId, errId, btnId, nxtId) {
    var pw = document.getElementById(pwId).value;
    var btn = document.getElementById(btnId);
    var errEl = document.getElementById(errId);
    var nxtEl = document.getElementById(nxtId);
    var nxt = nxtEl ? nxtEl.value : '/';
    if (!pw) { errEl.textContent = 'Please enter password'; return; }
    errEl.textContent = '';
    btn.disabled = true;
    var orig = btn.textContent;
    btn.textContent = 'Signing in…';
    fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: pw, role: (pwId === 'player-pw') ? 'player' : 'admin' })
    }).then(function(res) {
      return res.json().then(function(d) { return { ok: res.ok, d: d }; });
    }).then(function(r) {
      if (r.ok) {
        window.location.href = nxt || '/';
      } else {
        errEl.textContent = r.d.error || 'Incorrect password';
        btn.disabled = false; btn.textContent = orig;
      }
    }).catch(function() {
      errEl.textContent = 'Network error';
      btn.disabled = false; btn.textContent = orig;
    });
  }

  // Magic weapon trail effects
  window.addEventListener('load', function() {
    var canvas = document.getElementById('particles');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    function resize() { canvas.width = innerWidth; canvas.height = innerHeight; }
    resize(); window.addEventListener('resize', resize);

    var W, H;
    function getWH() { W = canvas.width; H = canvas.height; }
    getWH(); window.addEventListener('resize', getWH);

    // Weapon configs
    var WEAPONS = [
      { color: '#FFD700', glow: '#FFA500', size: 18, speed: 3.2, angle: -20 },
      { color: '#FFFFFF', glow: '#88CCFF', size: 22, speed: 2.8, angle: -12 },
      { color: '#00FF88', glow: '#00CC55', size: 16, speed: 3.8, angle: -8  },
      { color: '#4499FF', glow: '#0066FF', size: 20, speed: 2.5, angle: -15 },
      { color: '#FF44FF', glow: '#CC00CC', size: 14, speed: 4.0, angle: -5  },
      { color: '#FF4400', glow: '#FF8800', size: 19, speed: 3.5, angle: -18 },
      { color: '#00FFFF', glow: '#0088CC', size: 15, speed: 3.0, angle: -10 },
      { color: '#FFD700', glow: '#FF6600', size: 17, speed: 2.6, angle: -22 },
    ];

    var projectiles = [];
    var sparks = [];

    function spawnProjectile() {
      var w = WEAPONS[Math.floor(Math.random() * WEAPONS.length)];
      var ang = (w.angle + (Math.random() * 10 - 5)) * Math.PI / 180;
      var startY = H * 0.1 + Math.random() * H * 0.8;
      projectiles.push({
        x: -60, y: startY,
        vx: w.speed * Math.cos(ang) * (2 + Math.random()),
        vy: w.speed * Math.sin(ang),
        color: w.color, glow: w.glow, size: w.size,
        trail: [], life: 1, alpha: 0,
        angle: ang, fadeIn: true
      });
    }

    // Spawn projectiles over time
    var lastSpawn = 0;
    function maybeSpawn(t) {
      if (t - lastSpawn > 1200 + Math.random() * 1800) {
        spawnProjectile();
        lastSpawn = t;
      }
    }

    function drawWeapon(ctx, p) {
      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.angle);
      // Outer glow
      ctx.shadowBlur = 24;
      ctx.shadowColor = p.glow;
      // Blade
      var grad = ctx.createLinearGradient(-p.size, 0, p.size * 1.5, 0);
      grad.addColorStop(0, 'transparent');
      grad.addColorStop(0.3, p.color + 'aa');
      grad.addColorStop(0.7, p.color);
      grad.addColorStop(1, '#fff');
      ctx.strokeStyle = grad;
      ctx.lineWidth = 2.5;
      ctx.globalAlpha = p.alpha;
      ctx.beginPath();
      ctx.moveTo(-p.size, 0);
      ctx.lineTo(p.size * 2, 0);
      ctx.stroke();
      // Tip sparkle
      ctx.fillStyle = '#fff';
      ctx.shadowBlur = 16;
      ctx.shadowColor = p.color;
      ctx.beginPath();
      ctx.arc(p.size * 2, 0, 2.5, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    function drawTrail(ctx, p) {
      if (p.trail.length < 2) return;
      ctx.save();
      ctx.shadowBlur = 12;
      ctx.shadowColor = p.glow;
      for (var i = 1; i < p.trail.length; i++) {
        var t0 = p.trail[i-1], t1 = p.trail[i];
        var alpha = (i / p.trail.length) * 0.6 * p.alpha;
        var width = (i / p.trail.length) * 2.5;
        ctx.strokeStyle = p.color;
        ctx.globalAlpha = alpha;
        ctx.lineWidth = width;
        ctx.lineCap = 'round';
        ctx.beginPath();
        ctx.moveTo(t0.x, t0.y);
        ctx.lineTo(t1.x, t1.y);
        ctx.stroke();
      }
      ctx.restore();
    }

    function emitSparks(p) {
      if (Math.random() > 0.35) return;
      for (var i = 0; i < 2 + Math.floor(Math.random() * 3); i++) {
        sparks.push({
          x: p.x + (Math.random() - 0.5) * 8,
          y: p.y + (Math.random() - 0.5) * 8,
          vx: (Math.random() - 0.5) * 2,
          vy: -Math.random() * 1.5 - 0.5,
          life: 1, color: p.color, r: Math.random() * 1.5 + 0.5
        });
      }
    }

    function drawSpark(ctx, s) {
      ctx.save();
      ctx.globalAlpha = s.life * 0.8;
      ctx.shadowBlur = 8; ctx.shadowColor = s.color;
      ctx.fillStyle = s.color;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    var raf;
    function draw(t) {
      ctx.clearRect(0, 0, W, H);
      maybeSpawn(t);

      // Update + draw projectiles
      for (var i = projectiles.length - 1; i >= 0; i--) {
        var p = projectiles[i];
        p.trail.push({ x: p.x, y: p.y });
        if (p.trail.length > 28) p.trail.shift();
        p.x += p.vx; p.y += p.vy;
        p.alpha = p.fadeIn ? Math.min(1, p.alpha + 0.06) : Math.max(0, p.alpha - 0.04);
        if (p.alpha >= 0.95) p.fadeIn = false;
        if (p.x > W + 100 || p.y < -100 || p.y > H + 100) {
          p.fadeIn = false;
          if (p.alpha <= 0) { projectiles.splice(i, 1); continue; }
        }
        emitSparks(p);
        drawTrail(ctx, p);
        drawWeapon(ctx, p);
      }

      // Update + draw sparks
      for (var j = sparks.length - 1; j >= 0; j--) {
        var s = sparks[j];
        s.x += s.vx; s.y += s.vy; s.vy += 0.04; s.life -= 0.035;
        if (s.life <= 0) { sparks.splice(j, 1); continue; }
        drawSpark(ctx, s);
      }

      raf = requestAnimationFrame(draw);
    }
    raf = requestAnimationFrame(draw);
  });
</script>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}

/* ── Background ── */
body {
  font-family:'Josefin Sans',system-ui,sans-serif;letter-spacing:.04em;
  background:#06090F;
  min-height:100dvh; overflow:hidden;
}
.bg {
  position:fixed;inset:0;
  background:
    radial-gradient(ellipse 70% 60% at 20% 50%, rgba(212,175,55,0.07) 0%, transparent 60%),
    radial-gradient(ellipse 60% 70% at 80% 50%, rgba(10,20,40,0.8) 0%, transparent 70%),
    #06090F;
}
.bg-blob {
  position:fixed;border-radius:50%;filter:blur(100px);pointer-events:none;
}
.bg-blob-1{width:500px;height:500px;top:-100px;left:-100px;background:rgba(212,175,55,0.05);animation:bdrift 14s ease-in-out infinite alternate}
.bg-blob-2{width:400px;height:400px;bottom:-80px;right:-60px;background:rgba(120,39,13,0.06);animation:bdrift 18s ease-in-out infinite alternate-reverse}
@keyframes bdrift{from{transform:translate(0,0)}to{transform:translate(30px,20px)}}
#particles{position:fixed;inset:0;pointer-events:none;z-index:0}

/* ── Page ── */
.page {
  position:relative;z-index:10;
  min-height:100dvh;
  display:flex;align-items:center;justify-content:center;
  padding:1.5rem;
}

/* ── Split card ── */
.split-card {
  display:flex;
  width:100%;max-width:900px;
  min-height:min(560px, 90dvh);
  border-radius:24px;
  overflow:hidden;
  box-shadow:
    0 0 0 1px rgba(212,175,55,0.2),
    0 40px 100px rgba(0,0,0,0.8),
    0 0 60px rgba(212,175,55,0.06);
  animation:card-in .6s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes card-in{from{opacity:0;transform:scale(.94) translateY(24px)}to{opacity:1;transform:none}}

/* ══ LEFT PANEL ══ */
.left-panel {
  flex:1;
  background:linear-gradient(145deg, #0D1928 0%, #0A1020 60%, #070C18 100%);
  border-right:1px solid rgba(212,175,55,0.15);
  position:relative;overflow:hidden;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:2rem 1.5rem;
  min-height:320px;
}

/* Floating card suits around trophy */
.card-orbit {
  position:absolute;inset:0;pointer-events:none;z-index:0;
}
.co-card {
  position:absolute;
  font-family:Georgia,serif;font-weight:900;
  animation:co-float 6s ease-in-out infinite;
  opacity:0;
  animation-fill-mode:both;
}
/* Spades/Clubs = gold-tinted */
.co1,.co3,.co5,.co7{ color:rgba(212,175,55,0.55); }
/* Hearts/Diamonds = red-tinted */
.co2,.co4,.co6,.co8{ color:rgba(200,16,46,0.45); }

/* Position each card at a different spot around the trophy */
.co1{ font-size:2.2rem; top:8%;  left:10%;  animation-delay:0s;   animation-duration:7s; }
.co2{ font-size:1.6rem; top:5%;  right:12%; animation-delay:0.8s; animation-duration:6s; }
.co3{ font-size:1.4rem; top:35%; left:5%;   animation-delay:1.6s; animation-duration:8s; }
.co4{ font-size:1.8rem; top:30%; right:6%;  animation-delay:2.4s; animation-duration:5.5s; }
.co5{ font-size:2.5rem; bottom:25%;left:8%; animation-delay:3.2s; animation-duration:7.5s; }
.co6{ font-size:1.5rem; bottom:20%;right:10%;animation-delay:4s; animation-duration:6.5s; }
.co7{ font-size:1.2rem; bottom:8%; left:22%;animation-delay:1.2s; animation-duration:9s; }
.co8{ font-size:1.3rem; bottom:10%;right:20%;animation-delay:2s; animation-duration:7s; }

@keyframes co-float {
  0%   { opacity:0;    transform:translateY(8px)  scale(0.8) rotate(-8deg); }
  15%  { opacity:1; }
  50%  { opacity:0.8;  transform:translateY(-10px) scale(1.1) rotate(4deg); }
  85%  { opacity:1; }
  100% { opacity:0;    transform:translateY(8px)  scale(0.8) rotate(-8deg); }
}

/* Logo */
.lp-logo {
  position:absolute;top:1.25rem;left:1.25rem;
  display:flex;align-items:center;gap:.625rem;z-index:2;
}
.lp-logo-img{width:36px;height:36px;border-radius:9px;object-fit:cover;box-shadow:0 0 12px rgba(212,175,55,0.3)}
.lp-name{font-family:'Yeseva One',serif;font-size:.8125rem;font-weight:700;color:#D4AF37;letter-spacing:.08em}
.lp-sub{font-size:.45rem;color:rgba(212,175,55,0.4);font-weight:600;letter-spacing:.1em}

/* Trophy */
.lp-trophy {
  position:relative;z-index:2;
  display:flex;flex-direction:column;align-items:center;gap:.875rem;
  margin-top:1.5rem;
}
.trophy-glow-ring {
  position:absolute;width:220px;height:220px;border-radius:50%;
  background:radial-gradient(circle, rgba(212,175,55,0.14) 0%, transparent 65%);
  top:50%;left:50%;transform:translate(-50%,-50%);
  animation:ring-pulse 3s ease-in-out infinite;
  pointer-events:none;
}
@keyframes ring-pulse{0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.8}50%{transform:translate(-50%,-50%) scale(1.15);opacity:1}}
.trophy-glow-floor {
  position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);
  width:100px;height:12px;
  background:radial-gradient(ellipse, rgba(212,175,55,0.5) 0%, transparent 70%);
  filter:blur(6px);
  animation:floor-pulse 3s ease-in-out infinite;
}
@keyframes floor-pulse{0%,100%{opacity:.6;transform:translateX(-50%) scaleX(.9)}50%{opacity:1;transform:translateX(-50%) scaleX(1.2)}}
.lp-trophy-img {
  width:160px;height:auto;
  filter:drop-shadow(0 0 18px rgba(212,175,55,.7)) drop-shadow(0 6px 20px rgba(0,0,0,.6));
  animation:trophy-float 4s ease-in-out infinite;
  position:relative;z-index:1;
  border-radius:12px;
}
@keyframes trophy-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}

/* Trophy canvas wrap */
.trophy-canvas-wrap {
  position:relative;z-index:1;
  display:flex;justify-content:center;align-items:center;
  min-height:160px;
}

/* Card suit loading spinner */
.suit-loader {
  display:flex;gap:.5rem;align-items:center;
  height:60px;
}
.sl-suit {
  font-size:1.5rem;font-family:Georgia,serif;
  animation:suit-appear 1.2s ease-in-out infinite;
}
.sl-s1{color:#DDD1BF;animation-delay:0s}
.sl-s2{color:#C8102E;animation-delay:.3s}
.sl-s3{color:#DDD1BF;animation-delay:.6s}
.sl-s4{color:#C8102E;animation-delay:.9s}
@keyframes suit-appear{
  0%,100%{opacity:.2;transform:scale(.7) translateY(4px)}
  50%{opacity:1;transform:scale(1.2) translateY(-4px)}
}

/* Trophy canvas */
.trophy-canvas {
  width:160px;height:auto;
  animation:trophy-float 4s ease-in-out infinite;
  filter:
    drop-shadow(0 0 12px rgba(212,175,55,.9))
    drop-shadow(0 0 28px rgba(212,175,55,.5))
    drop-shadow(0 8px 20px rgba(0,0,0,.7));
}

/* DIGU LEAGUE label */
.trophy-league-name {
  display:flex;align-items:center;gap:.5rem;
  font-family:'Italiana',serif;
  font-size:.75rem;font-weight:900;
  color:#D4AF37;letter-spacing:.14em;
  text-shadow:0 0 20px rgba(212,175,55,.5);
  margin-top:.25rem;
}
.tln-suit{font-size:.625rem;font-family:Georgia,serif;opacity:.6}

/* Gold border pulsing ring around canvas */
.trophy-canvas-wrap::before {
  content:'';position:absolute;
  inset:-8px;border-radius:16px;
  border:1.5px solid rgba(212,175,55,0);
  animation:gold-border-pulse 2.5s ease-in-out infinite;
  pointer-events:none;
}
@keyframes gold-border-pulse{
  0%,100%{border-color:rgba(212,175,55,.2);box-shadow:0 0 0 rgba(212,175,55,0)}
  50%{border-color:rgba(212,175,55,.6);box-shadow:0 0 20px rgba(212,175,55,.2),0 0 40px rgba(212,175,55,.1)}
}

/* Bottom suits */
.lp-suits {
  position:absolute;bottom:1.125rem;
  display:flex;gap:.625rem;
  font-size:1rem;font-family:Georgia,serif;
}
.s-black{color:rgba(220,210,190,.25)}
.s-red{color:rgba(200,16,46,.3)}

/* ══ RIGHT PANEL ══ */
.right-panel {
  width:340px;flex-shrink:0;
  background:linear-gradient(160deg,#0C1828 0%,#080E1A 100%);
  display:flex;align-items:center;justify-content:center;
  padding:2rem 1.875rem;
  position:relative;
}
.right-panel::before {
  content:'';position:absolute;top:0;left:0;bottom:0;width:1px;
  background:linear-gradient(180deg,transparent,rgba(212,175,55,0.3),transparent);
}
.rp-inner{width:100%;position:relative;z-index:1}

/* Header */
.rp-header{margin-bottom:1.625rem;text-align:center}
.rp-crown-icon{width:56px;height:56px;margin-bottom:.375rem;filter:drop-shadow(0 0 10px rgba(212,175,55,.6));border-radius:12px;}
.rp-title{
  font-family:'Yeseva One',serif;
  font-size:1.625rem;font-weight:900;color:#D4AF37;
  letter-spacing:.06em;line-height:1;margin-bottom:.375rem;
  text-shadow:0 0 24px rgba(212,175,55,.4),0 2px 4px rgba(0,0,0,.6);
}
.rp-sub{font-size:.8125rem;color:rgba(200,180,140,.4);font-weight:400;letter-spacing:.04em;font-style:italic;font-family:"Cormorant Garamond",serif}

/* Tabs */
.rp-tabs{display:flex;background:rgba(0,0,0,.45);border:1px solid rgba(212,175,55,.2);border-radius:12px;padding:4px;gap:4px;margin-bottom:1.375rem}
.rp-tab{
  flex:1;padding:.625rem .5rem;border-radius:9px;
  font-family:'Cinzel',serif;font-size:.75rem;font-weight:700;
  letter-spacing:.08em;text-transform:uppercase;cursor:pointer;
  color:rgba(212,175,55,.35);transition:all .25s;
  display:flex;align-items:center;justify-content:center;gap:.375rem;
  border:1px solid transparent;background:transparent!important;-webkit-appearance:none;appearance:none;outline:none;
}
.rp-tab-icon{font-size:.875rem}
.rp-tab-active{
  background:linear-gradient(135deg,rgba(212,175,55,.18),rgba(212,175,55,.09));
  color:#D4AF37;
  border-color:rgba(212,175,55,.2);
  box-shadow:inset 0 1px 0 rgba(212,175,55,.12),0 2px 8px rgba(0,0,0,.3);
}
.rp-tab-admin-active{
  background:linear-gradient(135deg,rgba(120,39,13,.3),rgba(120,39,13,.15));
  color:#E88060;
  border-color:rgba(120,39,13,.35);
}

/* Hint */
.rp-hint{display:flex;align-items:center;gap:.5rem;font-size:.6875rem;font-weight:400;letter-spacing:.04em;color:rgba(200,180,140,.4);margin-bottom:1rem;padding:.5rem .75rem;background:rgba(212,175,55,.04);border:1px solid rgba(212,175,55,.08);border-radius:8px}
.rp-hint-red{background:rgba(120,39,13,.06);border-color:rgba(120,39,13,.15)}
.rp-hint-dot{width:6px;height:6px;border-radius:50%;background:#D4AF37;box-shadow:0 0 5px rgba(212,175,55,.7);flex-shrink:0;animation:dot-beat 2s ease-in-out infinite}
.rp-hint-dot-red{background:#C8102E;box-shadow:0 0 5px rgba(200,16,46,.7)}
@keyframes dot-beat{0%,100%{transform:scale(1)}50%{transform:scale(1.4)}}

/* Field */
.rp-field{margin-bottom:1rem}
.rp-label{display:block;font-size:.5rem;font-weight:700;text-transform:uppercase;letter-spacing:.2em;color:rgba(212,175,55,.4);margin-bottom:.5rem;font-family:'Josefin Sans',sans-serif}
.rp-iw{
  display:flex;align-items:center;
  background:#060C18;
  border:1.5px solid rgba(212,175,55,.2);
  border-radius:10px;overflow:hidden;transition:all .2s;
  box-shadow:inset 0 1px 4px rgba(0,0,0,.4);
}
.rp-iw.rp-iw-focus{border-color:rgba(212,175,55,.55);box-shadow:0 0 0 3px rgba(212,175,55,.08),inset 0 1px 4px rgba(0,0,0,.3)}
.rp-iw-icon{padding:0 .875rem;font-size:.9375rem;flex-shrink:0;opacity:.6}
.rp-input{
  flex:1;border:none;outline:none;
  background:#060C18 !important;
  color:#E8D8B8 !important;
  font-size:.9375rem;font-family:'Josefin Sans',sans-serif;letter-spacing:.04em;
  padding:.8125rem .5rem .8125rem 0;font-weight:600;min-width:0;
  -webkit-text-fill-color:#E8D8B8 !important;
}
.rp-input::placeholder{color:rgba(200,180,140,.2) !important;font-weight:500}
.rp-input:-webkit-autofill,
.rp-input:-webkit-autofill:hover,
.rp-input:-webkit-autofill:focus{
  -webkit-box-shadow:0 0 0 1000px #060C18 inset !important;
  -webkit-text-fill-color:#E8D8B8 !important;
}
.rp-eye{padding:0 .875rem;cursor:pointer;color:rgba(200,180,140,.3);transition:color .15s;display:flex;align-items:center;flex-shrink:0;border:none;background:none}
.rp-eye:hover{color:#D4AF37}

/* Error */
.rp-err{font-size:.75rem;color:#e05555;font-weight:700;min-height:1.2em;margin-bottom:.5rem;padding:0 .25rem}

/* Buttons */
.rp-btn{
  width:100%;padding:.9375rem;border-radius:10px;border:none;
  font-size:.8125rem;font-weight:800;cursor:pointer;
  font-family:'Josefin Sans',sans-serif;letter-spacing:.14em;text-transform:uppercase;
  transition:all .22s;min-height:50px;position:relative;overflow:hidden;
}
.rp-btn::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,255,255,.1) 0%,transparent 55%);pointer-events:none}
.rp-gold-btn{
  background:linear-gradient(135deg,#8A6A00,#BFA000,#D4AF37,#F0D060,#D4AF37);
  background-size:200%;color:#0E0900;
  box-shadow:0 4px 22px rgba(212,175,55,.45);
  animation:gold-shift 3s linear infinite;
}
@keyframes gold-shift{0%{background-position:0%}100%{background-position:200%}}
.rp-gold-btn:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 30px rgba(212,175,55,.65)}
.rp-ember-btn{
  background:linear-gradient(135deg,#3D0C04,#6E1F0B,#9A3018);
  color:#F5C4A8;box-shadow:0 4px 22px rgba(120,39,13,.5);
}
.rp-ember-btn:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 30px rgba(120,39,13,.7)}
.rp-btn:active{transform:translateY(0)!important}
.rp-btn:disabled{opacity:.5;cursor:not-allowed;transform:none!important}

.rp-footer{margin-top:1.5rem;font-size:.5rem;color:rgba(212,175,55,.2);letter-spacing:.14em;font-family:'Cinzel',serif;text-align:center;text-transform:uppercase}

/* OAuth error banner */
.rp-oauth-err{
  font-size:.75rem;color:#e88a6a;font-weight:700;text-align:center;
  background:rgba(120,39,13,.12);border:1px solid rgba(120,39,13,.3);
  border-radius:8px;padding:.5rem .75rem;margin-bottom:1rem;letter-spacing:.02em;
}

/* "or" divider */
.rp-or{display:flex;align-items:center;gap:.75rem;margin:1rem 0;color:rgba(200,180,140,.35);font-size:.6875rem;letter-spacing:.16em;text-transform:uppercase;font-family:'Cinzel',serif}
.rp-or::before,.rp-or::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(212,175,55,.22),transparent)}

/* Google button */
.rp-google-btn{
  display:flex;align-items:center;justify-content:center;gap:.625rem;
  width:100%;padding:.8125rem;border-radius:10px;
  background:#fff;color:#1f2937;text-decoration:none;
  font-family:'Josefin Sans',sans-serif;font-size:.8125rem;font-weight:700;letter-spacing:.06em;
  border:1px solid rgba(0,0,0,.1);box-shadow:0 2px 12px rgba(0,0,0,.3);
  transition:transform .18s,box-shadow .18s;
}
.rp-google-btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.45)}
.rp-google-btn:active{transform:translateY(0)}
.rp-google-btn svg{flex-shrink:0}

/* ── MOBILE ── */
@media(max-width:720px){
  html,body{overflow-y:auto}
  .page{padding:1rem;align-items:flex-start;min-height:100dvh}
  .split-card{flex-direction:column;max-width:440px;margin:0 auto}
  .left-panel{min-height:260px;padding:1.25rem 1rem 1rem}
  .lp-trophy-img{width:120px}
  .lp-logo-img{width:28px;height:28px}
  .lp-name{font-size:.6875rem}
  .lp-sub{display:none}
  .trophy-badge{font-size:.5625rem;padding:.25rem .625rem}
  .right-panel{width:100%;padding:1.5rem 1.25rem}
  .rp-title{font-size:1.375rem}
}
</style>

</body>
</html>
