---
export const prerender = false;
const next = Astro.url.searchParams.get('next') ?? '/';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#080C14" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="apple-touch-icon" href="/logo.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;600;700&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet" />
  <title>Digu League · Sign In</title>
</head>
<body>

<!-- Background -->
<div class="bg"></div>
<div class="bg-blob bg-blob-1"></div>
<div class="bg-blob bg-blob-2"></div>
<canvas id="particles"></canvas>

<!-- ── MAIN SPLIT CARD ── -->
<div class="page">
  <div class="split-card">

    <!-- ══ LEFT PANEL ══ -->
    <div class="left-panel">
      <!-- Blob shapes behind trophy -->
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>

      <!-- Logo top left -->
      <div class="lp-logo">
        <img src="/logo.png" alt="Digu League" class="lp-logo-img" />
        <div class="lp-logo-text">
          <div class="lp-name">Digu League</div>
          <div class="lp-sub">Play Smart · Win Big · Reign Supreme</div>
        </div>
      </div>

      <!-- Trophy center -->
      <div class="lp-trophy">
        <div class="trophy-glow-ring"></div>
        <div class="trophy-glow-floor"></div>
        <img
          src="/badges/champion-may-2026.png"
          alt="May 2026 Champion"
          class="lp-trophy-img"
        />
        <div class="trophy-badge">
          <span>👑</span>
          <span>May 2026 Champion</span>
          <span>·</span>
          <span>Mohamed Shujau</span>
        </div>
      </div>

      <!-- Bottom suits decoration -->
      <div class="lp-suits">
        <span class="s-black">♠</span>
        <span class="s-red">♥</span>
        <span class="s-black">♣</span>
        <span class="s-red">♦</span>
      </div>
    </div>

    <!-- ══ RIGHT PANEL ══ -->
    <div class="right-panel">
      <div class="rp-inner">

        <!-- Header -->
        <div class="rp-header">
          <h1 class="rp-title">Sign In</h1>
          <p class="rp-sub">Welcome back to the league</p>
        </div>

        <!-- Tabs -->
        <div class="rp-tabs">
          <button class="rp-tab rp-tab-active" id="tab-player" onclick="switchTab('player')">
            Player
          </button>
          <button class="rp-tab" id="tab-admin" onclick="switchTab('admin')">
            Admin
          </button>
        </div>

        <!-- Player form -->
        <div id="panel-player">
          <div class="rp-role-hint">
            <span class="rp-dot"></span>
            Start matches · Enter scores · Edit rounds
          </div>
          <form id="player-form">
            <input type="hidden" class="nxt" value={next} />
            <div class="rp-field">
              <label class="rp-label">Password</label>
              <div class="rp-input-wrap" id="iw-player">
                <input type="password" class="rp-input" id="player-pw"
                  placeholder="Enter player password"
                  autocomplete="current-password"
                  onfocus="document.getElementById('iw-player').classList.add('focus')"
                  onblur="document.getElementById('iw-player').classList.remove('focus')" />
                <button type="button" class="rp-eye" onclick="togglePw('player-pw',this)">
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>
            </div>
            <p class="rp-err" id="player-err"></p>
            <button type="submit" class="rp-btn rp-btn-gold" id="player-sub">
              Sign In as Player
            </button>
          </form>
        </div>

        <!-- Admin form -->
        <div id="panel-admin" style="display:none">
          <div class="rp-role-hint rp-role-admin">
            <span class="rp-dot rp-dot-red"></span>
            Full access · Manage players · All settings
          </div>
          <form id="admin-form">
            <input type="hidden" class="nxt" value={next} />
            <div class="rp-field">
              <label class="rp-label">Password</label>
              <div class="rp-input-wrap" id="iw-admin">
                <input type="password" class="rp-input" id="admin-pw"
                  placeholder="Enter admin password"
                  autocomplete="current-password"
                  onfocus="document.getElementById('iw-admin').classList.add('focus')"
                  onblur="document.getElementById('iw-admin').classList.remove('focus')" />
                <button type="button" class="rp-eye" onclick="togglePw('admin-pw',this)">
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>
            </div>
            <p class="rp-err" id="admin-err"></p>
            <button type="submit" class="rp-btn rp-btn-ember" id="admin-sub">
              Sign In as Admin
            </button>
          </form>
        </div>

        <div class="rp-footer">♠ ♥ ♣ ♦ &nbsp; Gin Rummy Competition</div>
      </div>
    </div>

  </div>
</div>

<script>
  function switchTab(r) {
    const p = r === 'player';
    document.getElementById('panel-player').style.display = p ? '' : 'none';
    document.getElementById('panel-admin').style.display = p ? 'none' : '';
    document.getElementById('tab-player').classList.toggle('rp-tab-active', p);
    document.getElementById('tab-admin').classList.toggle('rp-tab-active', !p);
  }
  function togglePw(id, btn) {
    const i = document.getElementById(id);
    i.type = i.type === 'password' ? 'text' : 'password';
    btn.querySelector('svg').style.opacity = i.type === 'text' ? '0.4' : '1';
  }
  async function doLogin(pw, nxt, errEl, btn) {
    errEl.textContent = '';
    btn.disabled = true;
    const orig = btn.textContent;
    btn.textContent = 'Signing in…';
    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ password: pw }),
      });
      if (res.ok) { window.location.href = nxt || '/'; }
      else {
        const d = await res.json();
        errEl.textContent = d.error || 'Incorrect password';
        btn.disabled = false; btn.textContent = orig;
      }
    } catch {
      errEl.textContent = 'Network error';
      btn.disabled = false; btn.textContent = orig;
    }
  }
  document.getElementById('player-form').addEventListener('submit', e => {
    e.preventDefault();
    doLogin(document.getElementById('player-pw').value,
      e.currentTarget.querySelector('.nxt').value,
      document.getElementById('player-err'),
      document.getElementById('player-sub'));
  });
  document.getElementById('admin-form').addEventListener('submit', e => {
    e.preventDefault();
    doLogin(document.getElementById('admin-pw').value,
      e.currentTarget.querySelector('.nxt').value,
      document.getElementById('admin-err'),
      document.getElementById('admin-sub'));
  });

  // Gold dust particles
  const canvas = document.getElementById('particles');
  const ctx = canvas.getContext('2d');
  function resize() { canvas.width = innerWidth; canvas.height = innerHeight; }
  resize(); window.addEventListener('resize', resize);
  const pts = Array.from({length:50}, () => ({
    x: Math.random()*innerWidth, y: Math.random()*innerHeight,
    r: Math.random()*1.2+0.3, vx:(Math.random()-.5)*.25,
    vy:-Math.random()*.3-.05, o: Math.random()*.4+.05,
  }));
  function draw() {
    ctx.clearRect(0,0,canvas.width,canvas.height);
    pts.forEach(p => {
      ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle = `rgba(212,175,55,${p.o})`; ctx.fill();
      p.x+=p.vx; p.y+=p.vy;
      if (p.y<-5) { p.y=canvas.height+5; p.x=Math.random()*canvas.width; }
    });
    requestAnimationFrame(draw);
  }
  draw();
</script>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}

/* ── Background ── */
body {
  font-family:'Quicksand',system-ui,sans-serif;
  background:#06090F;
  min-height:100dvh; overflow:hidden;
}
.bg {
  position:fixed;inset:0;
  background:
    radial-gradient(ellipse 70% 60% at 20% 50%, rgba(212,175,55,0.07) 0%, transparent 60%),
    radial-gradient(ellipse 60% 70% at 80% 50%, rgba(10,20,40,0.8) 0%, transparent 70%),
    #06090F;
}
.bg-blob {
  position:fixed;border-radius:50%;filter:blur(100px);pointer-events:none;
}
.bg-blob-1{width:500px;height:500px;top:-100px;left:-100px;background:rgba(212,175,55,0.05);animation:bdrift 14s ease-in-out infinite alternate}
.bg-blob-2{width:400px;height:400px;bottom:-80px;right:-60px;background:rgba(120,39,13,0.06);animation:bdrift 18s ease-in-out infinite alternate-reverse}
@keyframes bdrift{from{transform:translate(0,0)}to{transform:translate(30px,20px)}}
#particles{position:fixed;inset:0;pointer-events:none;z-index:0}

/* ── Page ── */
.page {
  position:relative;z-index:10;
  min-height:100dvh;
  display:flex;align-items:center;justify-content:center;
  padding:1.5rem;
}

/* ── Split card ── */
.split-card {
  display:flex;
  width:100%;max-width:900px;
  min-height:min(560px, 90dvh);
  border-radius:24px;
  overflow:hidden;
  box-shadow:
    0 0 0 1px rgba(212,175,55,0.2),
    0 40px 100px rgba(0,0,0,0.8),
    0 0 60px rgba(212,175,55,0.06);
  animation:card-in .6s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes card-in{from{opacity:0;transform:scale(.94) translateY(24px)}to{opacity:1;transform:none}}

/* ══ LEFT PANEL ══ */
.left-panel {
  flex:1;
  background:linear-gradient(145deg, #0D1928 0%, #0A1020 60%, #070C18 100%);
  border-right:1px solid rgba(212,175,55,0.15);
  position:relative;overflow:hidden;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:2rem 1.5rem;
  min-height:320px;
}

/* Organic blobs */
.blob {
  position:absolute;border-radius:50%;pointer-events:none;
}
.blob-1 {
  width:280px;height:280px;
  background:radial-gradient(circle, rgba(212,175,55,0.09) 0%, transparent 70%);
  top:50%;left:50%;transform:translate(-50%,-50%);
  animation:blob-pulse 5s ease-in-out infinite;
}
.blob-2 {
  width:200px;height:200px;
  background:radial-gradient(circle, rgba(212,175,55,0.06) 0%, transparent 70%);
  top:30%;left:40%;
  animation:blob-pulse 7s ease-in-out infinite reverse;
}
.blob-3 {
  width:160px;height:160px;
  background:radial-gradient(circle, rgba(120,39,13,0.08) 0%, transparent 70%);
  bottom:20%;right:15%;
  animation:blob-pulse 6s ease-in-out infinite 2s;
}
@keyframes blob-pulse{0%,100%{transform:translate(-50%,-50%) scale(1)}50%{transform:translate(-50%,-50%) scale(1.2)}}
.blob-2,.blob-3{transform:none}
@keyframes blob-pulse2{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
.blob-2,.blob-3{animation-name:blob-pulse2}

/* Logo */
.lp-logo {
  position:absolute;top:1.25rem;left:1.25rem;
  display:flex;align-items:center;gap:.625rem;z-index:2;
}
.lp-logo-img{width:36px;height:36px;border-radius:9px;object-fit:cover;box-shadow:0 0 12px rgba(212,175,55,0.3)}
.lp-name{font-family:'Cinzel',serif;font-size:.8125rem;font-weight:700;color:#D4AF37;letter-spacing:.08em}
.lp-sub{font-size:.45rem;color:rgba(212,175,55,0.4);font-weight:600;letter-spacing:.1em}

/* Trophy */
.lp-trophy {
  position:relative;z-index:2;
  display:flex;flex-direction:column;align-items:center;gap:.875rem;
  margin-top:1.5rem;
}
.trophy-glow-ring {
  position:absolute;width:220px;height:220px;border-radius:50%;
  background:radial-gradient(circle, rgba(212,175,55,0.14) 0%, transparent 65%);
  top:50%;left:50%;transform:translate(-50%,-50%);
  animation:ring-pulse 3s ease-in-out infinite;
  pointer-events:none;
}
@keyframes ring-pulse{0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.8}50%{transform:translate(-50%,-50%) scale(1.15);opacity:1}}
.trophy-glow-floor {
  position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);
  width:100px;height:12px;
  background:radial-gradient(ellipse, rgba(212,175,55,0.5) 0%, transparent 70%);
  filter:blur(6px);
  animation:floor-pulse 3s ease-in-out infinite;
}
@keyframes floor-pulse{0%,100%{opacity:.6;transform:translateX(-50%) scaleX(.9)}50%{opacity:1;transform:translateX(-50%) scaleX(1.2)}}
.lp-trophy-img {
  width:160px;height:auto;
  mix-blend-mode:multiply;
  filter:drop-shadow(0 0 18px rgba(212,175,55,.7)) drop-shadow(0 6px 20px rgba(0,0,0,.8));
  animation:trophy-float 4s ease-in-out infinite;
  position:relative;z-index:1;
}
@keyframes trophy-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.trophy-badge {
  display:flex;align-items:center;gap:.375rem;
  background:linear-gradient(135deg,rgba(212,175,55,.1),rgba(212,175,55,.06));
  border:1px solid rgba(212,175,55,.3);border-radius:30px;
  padding:.35rem .875rem;
  font-size:.6875rem;font-weight:700;color:rgba(212,175,55,.85);
  font-family:'Cinzel',serif;letter-spacing:.04em;
  white-space:nowrap;
}

/* Bottom suits */
.lp-suits {
  position:absolute;bottom:1.125rem;
  display:flex;gap:.625rem;
  font-size:1rem;font-family:Georgia,serif;
}
.s-black{color:rgba(220,210,190,.25)}
.s-red{color:rgba(200,16,46,.3)}

/* ══ RIGHT PANEL ══ */
.right-panel {
  width:340px;flex-shrink:0;
  background:linear-gradient(160deg,#0B1520 0%,#080F1A 100%);
  display:flex;align-items:center;justify-content:center;
  padding:2rem 2rem;
}
.rp-inner{width:100%}

.rp-header{margin-bottom:1.5rem}
.rp-title {
  font-family:'Cinzel Decorative',serif;
  font-size:1.75rem;font-weight:900;
  color:#D4AF37;letter-spacing:.04em;
  text-shadow:0 0 30px rgba(212,175,55,.4);
  margin-bottom:.25rem;
}
.rp-sub{font-size:.75rem;color:rgba(200,180,140,.4);font-weight:600;letter-spacing:.06em}

/* Tabs */
.rp-tabs{display:flex;gap:4px;background:rgba(0,0,0,.4);border:1px solid rgba(212,175,55,.14);border-radius:10px;padding:3px;margin-bottom:1.25rem}
.rp-tab{flex:1;padding:.5625rem;border-radius:8px;font-family:'Cinzel',serif;font-size:.75rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;color:rgba(212,175,55,.35);transition:all .2s}
.rp-tab-active{background:linear-gradient(135deg,rgba(212,175,55,.16),rgba(212,175,55,.08));color:#D4AF37;box-shadow:inset 0 1px 0 rgba(212,175,55,.1)}

/* Role hint */
.rp-role-hint{display:flex;align-items:center;gap:.5rem;font-size:.6875rem;font-weight:600;color:rgba(200,180,140,.4);margin-bottom:1rem}
.rp-role-admin{color:rgba(220,140,100,.4)}
.rp-dot{width:6px;height:6px;border-radius:50%;background:#D4AF37;box-shadow:0 0 5px rgba(212,175,55,.7);flex-shrink:0;animation:dot-beat 2s ease-in-out infinite}
.rp-dot-red{background:#C8102E;box-shadow:0 0 5px rgba(200,16,46,.7)}
@keyframes dot-beat{0%,100%{transform:scale(1)}50%{transform:scale(1.4)}}

/* Field */
.rp-field{margin-bottom:.875rem}
.rp-label{display:block;font-size:.5rem;font-weight:800;text-transform:uppercase;letter-spacing:.18em;color:rgba(212,175,55,.45);margin-bottom:.4375rem;font-family:'Cinzel',serif}
.rp-input-wrap{display:flex;align-items:center;background:rgba(0,0,0,.5);border:1px solid rgba(212,175,55,.16);border-radius:10px;overflow:hidden;transition:all .2s}
.rp-input-wrap.focus{border-color:rgba(212,175,55,.5);box-shadow:0 0 0 3px rgba(212,175,55,.07)}
.rp-input{flex:1;background:none;border:none;outline:none;color:#E8D8B8;font-size:.9375rem;font-family:'Quicksand',sans-serif;padding:.75rem 1rem;font-weight:600;min-width:0;letter-spacing:.04em}
.rp-input::placeholder{color:rgba(200,180,140,.18);letter-spacing:0;font-weight:500}
.rp-eye{padding:0 .875rem;cursor:pointer;color:rgba(200,180,140,.35);transition:color .15s;display:flex;align-items:center;flex-shrink:0}
.rp-eye:hover{color:#D4AF37}

/* Error */
.rp-err{font-size:.75rem;color:#e05555;font-weight:700;min-height:1.2em;margin-bottom:.5rem}

/* Buttons */
.rp-btn{width:100%;padding:.875rem;border-radius:10px;border:none;font-size:.875rem;font-weight:800;cursor:pointer;font-family:'Cinzel',serif;letter-spacing:.1em;text-transform:uppercase;transition:all .22s;min-height:50px;position:relative;overflow:hidden}
.rp-btn::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,255,255,.1) 0%,transparent 55%);pointer-events:none}
.rp-btn-gold{background:linear-gradient(135deg,#8A6A00,#BFA000,#D4AF37,#EDD060);background-size:200%;color:#120E00;box-shadow:0 4px 20px rgba(212,175,55,.4);animation:gold-shift 3s linear infinite}
@keyframes gold-shift{0%{background-position:0%}100%{background-position:200%}}
.rp-btn-gold:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 28px rgba(212,175,55,.6)}
.rp-btn-ember{background:linear-gradient(135deg,#3D0C04,#6E1F0B,#9A3018);color:#F5C4A8;box-shadow:0 4px 20px rgba(120,39,13,.5)}
.rp-btn-ember:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 28px rgba(120,39,13,.65)}
.rp-btn:active{transform:translateY(0)!important}
.rp-btn:disabled{opacity:.5;cursor:not-allowed;transform:none!important}

.rp-footer{margin-top:1.5rem;font-size:.5625rem;color:rgba(212,175,55,.2);letter-spacing:.12em;font-family:'Cinzel',serif;text-align:center}

/* ── MOBILE ── */
@media(max-width:720px){
  html,body{overflow-y:auto}
  .page{padding:1rem;align-items:flex-start;min-height:100dvh}
  .split-card{flex-direction:column;max-width:440px;margin:0 auto}
  .left-panel{min-height:260px;padding:1.25rem 1rem 1rem}
  .lp-trophy-img{width:120px}
  .lp-logo-img{width:28px;height:28px}
  .lp-name{font-size:.6875rem}
  .lp-sub{display:none}
  .trophy-badge{font-size:.5625rem;padding:.25rem .625rem}
  .right-panel{width:100%;padding:1.5rem 1.25rem}
  .rp-title{font-size:1.375rem}
}
</style>

</body>
</html>
