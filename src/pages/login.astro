---
export const prerender = false;
const next = Astro.url.searchParams.get('next') ?? '/';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#0B0F1A" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="apple-touch-icon" href="/logo.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;600;700&family=Playfair+Display:ital,wght@0,700;0,900;1,700&display=swap" rel="stylesheet" />
  <title>Digu League</title>
</head>
<body>

<!-- ── ANIMATED BACKGROUND ── -->
<div class="bg-felt"></div>
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="bg-glow bg-glow-3"></div>

<!-- Floating cards -->
<div class="fc fc1"><div class="fc-inner"><div class="fc-front">A<span>♠</span></div><div class="fc-back"></div></div></div>
<div class="fc fc2"><div class="fc-inner"><div class="fc-front red">K<span>♥</span></div><div class="fc-back"></div></div></div>
<div class="fc fc3"><div class="fc-inner"><div class="fc-front">Q<span>♣</span></div><div class="fc-back"></div></div></div>
<div class="fc fc4"><div class="fc-inner"><div class="fc-front red">J<span>♦</span></div><div class="fc-back"></div></div></div>
<div class="fc fc5"><div class="fc-inner"><div class="fc-front">10<span>♠</span></div><div class="fc-back"></div></div></div>
<div class="fc fc6"><div class="fc-inner"><div class="fc-front red">A<span>♥</span></div><div class="fc-back"></div></div></div>
<div class="fc fc7"><div class="fc-inner"><div class="fc-front">K<span>♠</span></div><div class="fc-back"></div></div></div>
<div class="fc fc8"><div class="fc-inner"><div class="fc-front red">Q<span>♦</span></div><div class="fc-back"></div></div></div>

<!-- Chip particles -->
<div class="chip-particle cp1">🪙</div>
<div class="chip-particle cp2">🃏</div>
<div class="chip-particle cp3">🪙</div>
<div class="chip-particle cp4">🃏</div>

<!-- ── MAIN CONTENT ── -->
<div class="page">

  <!-- Logo section -->
  <div class="hero">
    <div class="logo-ring">
      <div class="logo-ring-inner"></div>
      <img src="/logo.png" alt="Digu League" class="hero-logo" />
    </div>
    <h1 class="hero-title">Digu League</h1>
    <p class="hero-sub">GIN RUMMY · COMPETITION TRACKER</p>
    <div class="hero-suits">
      <span class="suit black">♠</span>
      <span class="suit red">♥</span>
      <span class="suit black">♣</span>
      <span class="suit red">♦</span>
    </div>
  </div>

  <!-- Login card -->
  <div class="login-card">

    <!-- Tab switcher -->
    <div class="tabs">
      <button class="tab active" id="tab-player" onclick="switchTab('player')">
        🎴 Player
      </button>
      <button class="tab" id="tab-admin" onclick="switchTab('admin')">
        ⚙️ Admin
      </button>
    </div>

    <!-- Player panel -->
    <div id="panel-player" class="panel">
      <div class="access-info player-info">
        <div class="access-dots">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
        </div>
        <span>Start matches · Enter scores · Edit rounds</span>
      </div>
      <form id="player-form">
        <input type="hidden" class="nxt" value={next} />
        <div class="field">
          <label class="lbl">Player Password</label>
          <div class="inp-row">
            <span class="inp-icon">🔑</span>
            <input type="password" id="player-pw" class="inp"
              placeholder="••••••••" autocomplete="current-password" />
            <button type="button" class="eye" onclick="togglePw('player-pw',this)">👁</button>
          </div>
        </div>
        <p class="err" id="player-err"></p>
        <button type="submit" class="sbtn player-sbtn" id="player-sub">
          Sign In as Player →
        </button>
      </form>
    </div>

    <!-- Admin panel -->
    <div id="panel-admin" class="panel" style="display:none">
      <div class="access-info admin-info">
        <div class="access-dots">
          <span class="dot red"></span><span class="dot red"></span><span class="dot red"></span>
        </div>
        <span>Full access · Manage players · All settings</span>
      </div>
      <form id="admin-form">
        <input type="hidden" class="nxt" value={next} />
        <div class="field">
          <label class="lbl">Admin Password</label>
          <div class="inp-row">
            <span class="inp-icon">🔐</span>
            <input type="password" id="admin-pw" class="inp"
              placeholder="••••••••" autocomplete="current-password" />
            <button type="button" class="eye" onclick="togglePw('admin-pw',this)">👁</button>
          </div>
        </div>
        <p class="err" id="admin-err"></p>
        <button type="submit" class="sbtn admin-sbtn" id="admin-sub">
          Sign In as Admin →
        </button>
      </form>
    </div>

  </div>

</div>

<script>
  function switchTab(r) {
    const p = r === 'player';
    document.getElementById('panel-player').style.display = p ? '' : 'none';
    document.getElementById('panel-admin').style.display = p ? 'none' : '';
    document.getElementById('tab-player').classList.toggle('active', p);
    document.getElementById('tab-admin').classList.toggle('active', !p);
  }
  function togglePw(id, btn) {
    const i = document.getElementById(id);
    i.type = i.type === 'password' ? 'text' : 'password';
    btn.textContent = i.type === 'password' ? '👁' : '🙈';
  }
  async function doLogin(pw, next, errEl, btn) {
    errEl.textContent = '';
    btn.disabled = true;
    const orig = btn.textContent;
    btn.textContent = 'Signing in…';
    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pw }),
      });
      if (res.ok) { window.location.href = next || '/'; }
      else {
        const d = await res.json();
        errEl.textContent = d.error || 'Incorrect password';
        btn.disabled = false; btn.textContent = orig;
      }
    } catch {
      errEl.textContent = 'Network error';
      btn.disabled = false; btn.textContent = orig;
    }
  }
  document.getElementById('player-form').addEventListener('submit', e => {
    e.preventDefault();
    doLogin(document.getElementById('player-pw').value,
      e.currentTarget.querySelector('.nxt').value,
      document.getElementById('player-err'),
      document.getElementById('player-sub'));
  });
  document.getElementById('admin-form').addEventListener('submit', e => {
    e.preventDefault();
    doLogin(document.getElementById('admin-pw').value,
      e.currentTarget.querySelector('.nxt').value,
      document.getElementById('admin-err'),
      document.getElementById('admin-sub'));
  });
</script>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; }

body {
  font-family: 'Quicksand', system-ui, sans-serif;
  background: #07090F;
  color: #DDD1BF;
  min-height: 100dvh;
  overflow-x: hidden;
  position: relative;
}

/* ── Background ── */
.bg-felt {
  position: fixed; inset: 0; z-index: 0;
  background:
    radial-gradient(ellipse 120% 80% at 50% 0%, #0D1628 0%, transparent 60%),
    radial-gradient(ellipse 80% 60% at 20% 100%, #130C1C 0%, transparent 50%),
    #07090F;
  background-image:
    radial-gradient(ellipse 120% 80% at 50% 0%, #0D1628 0%, transparent 60%),
    radial-gradient(ellipse 80% 60% at 20% 100%, #130C1C 0%, transparent 50%),
    repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.012) 40px),
    repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.012) 40px);
}

.bg-glow {
  position: fixed; border-radius: 50%; pointer-events: none; z-index: 0;
  filter: blur(80px); animation: glow-drift 8s ease-in-out infinite alternate;
}
.bg-glow-1 { width: 500px; height: 500px; top: -150px; left: -100px; background: rgba(212,175,55,0.06); animation-delay: 0s; }
.bg-glow-2 { width: 400px; height: 400px; bottom: -100px; right: -80px; background: rgba(200,16,46,0.07); animation-delay: 3s; }
.bg-glow-3 { width: 350px; height: 350px; top: 40%; left: 40%; background: rgba(43,79,55,0.08); animation-delay: 6s; }
@keyframes glow-drift {
  from { transform: scale(1) translate(0,0); }
  to   { transform: scale(1.15) translate(20px,20px); }
}

/* ── Floating cards ── */
.fc {
  position: fixed; width: 54px; height: 78px;
  perspective: 600px; z-index: 1; pointer-events: none;
  animation: fc-float 20s ease-in-out infinite;
}
.fc-inner {
  width: 100%; height: 100%;
  transform-style: preserve-3d;
  animation: fc-flip 6s ease-in-out infinite;
  border-radius: 8px;
}
.fc-front, .fc-back {
  position: absolute; inset: 0; border-radius: 8px;
  backface-visibility: hidden;
}
.fc-front {
  background: #fff; color: #1a1a2e;
  display: flex; flex-direction: column; align-items: flex-start;
  justify-content: flex-start; padding: 5px 6px;
  font-family: Georgia, serif; font-size: 14px; font-weight: 900;
  box-shadow: 0 4px 20px rgba(0,0,0,0.6);
  opacity: 0.7;
}
.fc-front span { font-size: 16px; display: block; line-height: 1; }
.fc-front.red { color: #C8102E; }
.fc-back {
  background: linear-gradient(135deg, #1a3a2a 0%, #0d1f17 100%);
  border: 2px solid rgba(212,175,55,0.3);
  transform: rotateY(180deg);
  box-shadow: 0 4px 20px rgba(0,0,0,0.6);
}
.fc-back::after {
  content: '🃏'; position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center; font-size: 20px;
  opacity: 0.4;
}

/* Card positions & animations */
.fc1  { top:5%;  left:3%;  animation-delay:0s;  animation-duration:18s }
.fc2  { top:15%; right:4%; animation-delay:2s;  animation-duration:22s }
.fc3  { top:55%; left:2%;  animation-delay:4s;  animation-duration:20s }
.fc4  { top:70%; right:3%; animation-delay:1s;  animation-duration:25s }
.fc5  { top:30%; left:6%;  animation-delay:3s;  animation-duration:19s }
.fc6  { top:80%; left:25%; animation-delay:5s;  animation-duration:21s }
.fc7  { top:10%; right:15%;animation-delay:7s;  animation-duration:23s }
.fc8  { top:65%; right:20%;animation-delay:6s;  animation-duration:17s }

@keyframes fc-float {
  0%,100% { transform: translateY(0) rotate(-5deg); }
  25%      { transform: translateY(-18px) rotate(3deg); }
  50%      { transform: translateY(-8px) rotate(-2deg); }
  75%      { transform: translateY(-22px) rotate(5deg); }
}
@keyframes fc-flip {
  0%,40%,100% { transform: rotateY(0deg); }
  50%,90%     { transform: rotateY(180deg); }
}

/* ── Chip particles ── */
.chip-particle {
  position: fixed; font-size: 1.5rem; pointer-events: none; z-index: 1;
  animation: chip-float 10s ease-in-out infinite;
  opacity: 0.15;
}
.cp1 { bottom:15%; left:8%;  animation-delay:0s }
.cp2 { top:20%;    right:8%; animation-delay:3s }
.cp3 { top:45%;    left:12%; animation-delay:6s }
.cp4 { bottom:25%; right:12%;animation-delay:9s }
@keyframes chip-float {
  0%,100% { transform: translateY(0) scale(1); opacity:0.15; }
  50%      { transform: translateY(-16px) scale(1.1); opacity:0.25; }
}

/* ── Page layout ── */
.page {
  position: relative; z-index: 10;
  min-height: 100dvh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 2rem 1rem 3rem;
  gap: 2rem;
}

/* ── Hero ── */
.hero { text-align: center; }

.logo-ring {
  position: relative; width: 110px; height: 110px;
  margin: 0 auto 1.125rem;
}
.logo-ring-inner {
  position: absolute; inset: -8px; border-radius: 50%;
  border: 2px solid transparent;
  background: linear-gradient(135deg, #D4AF37, #C8102E, #2B4F37, #D4AF37) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: destination-out;
  mask-composite: exclude;
  animation: ring-spin 8s linear infinite;
}
@keyframes ring-spin { to { transform: rotate(360deg); } }

.hero-logo {
  width: 110px; height: 110px; border-radius: 26px;
  position: relative; z-index: 1;
  box-shadow:
    0 0 0 1px rgba(212,175,55,0.25),
    0 20px 60px rgba(0,0,0,0.7),
    0 0 40px rgba(212,175,55,0.2);
  animation: logo-pulse 3s ease-in-out infinite;
}
@keyframes logo-pulse {
  0%,100% { box-shadow: 0 0 0 1px rgba(212,175,55,0.25), 0 20px 60px rgba(0,0,0,.7), 0 0 40px rgba(212,175,55,.2); }
  50%      { box-shadow: 0 0 0 1px rgba(212,175,55,0.4),  0 20px 60px rgba(0,0,0,.7), 0 0 60px rgba(212,175,55,.35); }
}

.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 8vw, 3rem);
  font-weight: 900; color: #D4AF37; letter-spacing: -0.02em; line-height: 1;
  margin-bottom: 0.5rem;
  text-shadow: 0 0 40px rgba(212,175,55,0.4), 0 0 80px rgba(212,175,55,0.15);
  animation: title-shimmer 4s ease-in-out infinite;
}
@keyframes title-shimmer {
  0%,100% { text-shadow: 0 0 40px rgba(212,175,55,0.4), 0 0 80px rgba(212,175,55,0.15); }
  50%      { text-shadow: 0 0 60px rgba(212,175,55,0.6), 0 0 120px rgba(212,175,55,0.25); }
}

.hero-sub {
  font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.22em;
  color: #6a9bc8; text-transform: uppercase; margin-bottom: 1.25rem;
}

.hero-suits {
  display: flex; gap: 0.875rem; justify-content: center; align-items: center;
}
.suit {
  font-size: 1.375rem; font-family: Georgia, serif;
  animation: suit-bounce 2s ease-in-out infinite;
  display: inline-block;
}
.suit:nth-child(1) { animation-delay: 0s; }
.suit:nth-child(2) { animation-delay: 0.2s; }
.suit:nth-child(3) { animation-delay: 0.4s; }
.suit:nth-child(4) { animation-delay: 0.6s; }
.suit.black { color: #DDD1BF; }
.suit.red   { color: #C8102E; }
@keyframes suit-bounce {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-5px); }
}

/* ── Login card ── */
.login-card {
  width: 100%; max-width: 400px;
  background: rgba(13,21,37,0.85);
  border: 1px solid rgba(212,175,55,0.15);
  border-radius: 20px;
  padding: 1.75rem 1.5rem;
  backdrop-filter: blur(20px);
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.04),
    0 24px 80px rgba(0,0,0,0.7),
    inset 0 1px 0 rgba(255,255,255,0.06);
  animation: card-appear 0.6s cubic-bezier(0.34,1.56,0.64,1) both;
}
@keyframes card-appear {
  from { opacity:0; transform: translateY(30px) scale(0.95); }
  to   { opacity:1; transform: none; }
}

/* ── Tabs ── */
.tabs {
  display: flex; gap: 4px;
  background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.06);
  border-radius: 12px; padding: 4px; margin-bottom: 1.25rem;
}
.tab {
  flex: 1; padding: 0.625rem 0.5rem; border-radius: 9px;
  font-size: 0.875rem; font-weight: 700; cursor: pointer;
  color: #6a9bc8; transition: all 0.25s; font-family: 'Quicksand', sans-serif;
}
.tab.active {
  background: rgba(212,175,55,0.12);
  color: #D4AF37;
  box-shadow: 0 1px 8px rgba(212,175,55,0.15);
}

/* ── Access info ── */
.access-info {
  display: flex; align-items: center; gap: 0.75rem;
  border-radius: 10px; padding: 0.625rem 0.875rem; margin-bottom: 1.25rem;
  font-size: 0.75rem; font-weight: 600; color: #6a9bc8;
}
.player-info { background: rgba(212,175,55,0.05); border: 1px solid rgba(212,175,55,0.14); }
.admin-info  { background: rgba(120,39,13,0.08);  border: 1px solid rgba(120,39,13,0.25); }
.access-dots { display: flex; gap: 4px; flex-shrink: 0; }
.dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(212,175,55,0.5); display: block; }
.dot.red { background: rgba(200,16,46,0.6); }

/* ── Field ── */
.field { margin-bottom: 0.875rem; }
.lbl {
  display: block; font-size: 0.5625rem; font-weight: 800;
  text-transform: uppercase; letter-spacing: 0.14em;
  color: #6a9bc8; margin-bottom: 0.5rem;
}
.inp-row {
  display: flex; align-items: center;
  background: rgba(0,0,0,0.35); border: 1.5px solid rgba(255,255,255,0.08);
  border-radius: 10px; overflow: hidden; transition: all 0.2s;
}
.inp-row:focus-within {
  border-color: rgba(212,175,55,0.5);
  box-shadow: 0 0 0 3px rgba(212,175,55,0.08);
}
.inp-icon { padding: 0 0.75rem; font-size: 1rem; flex-shrink: 0; }
.inp {
  flex: 1; background: none; border: none; outline: none;
  color: #DDD1BF; font-size: 1rem; font-family: inherit;
  padding: 0.75rem 0; font-weight: 600; min-width: 0;
  letter-spacing: 0.05em;
}
.inp::placeholder { color: #1e3a5a; letter-spacing: 0; }
.eye { padding: 0 0.75rem; font-size: 1rem; cursor: pointer; color: #6a9bc8; flex-shrink: 0; }

/* ── Error ── */
.err {
  font-size: 0.8125rem; color: #C8102E; font-weight: 600;
  min-height: 1.25em; margin-bottom: 0.5rem;
}

/* ── Submit buttons ── */
.sbtn {
  width: 100%; padding: 0.9375rem; border-radius: 12px; border: none;
  font-size: 1rem; font-weight: 800; cursor: pointer;
  font-family: 'Quicksand', sans-serif; letter-spacing: 0.02em;
  transition: all 0.2s; min-height: 52px; position: relative; overflow: hidden;
}
.sbtn::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.12) 0%, transparent 60%);
  pointer-events: none;
}
.player-sbtn {
  background: linear-gradient(135deg, #A8880A, #D4AF37, #EDD060);
  color: #0B0F1A;
  box-shadow: 0 4px 24px rgba(212,175,55,0.4);
}
.player-sbtn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(212,175,55,0.55);
}
.admin-sbtn {
  background: linear-gradient(135deg, #5C1A08, #78270D, #B03A1A);
  color: #FFF0E8;
  box-shadow: 0 4px 24px rgba(120,39,13,0.5);
}
.admin-sbtn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(120,39,13,0.65);
}
.sbtn:active { transform: translateY(0); }
.sbtn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
</style>

</body>
</html>
