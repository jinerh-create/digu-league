---
export const prerender = false;
const next = Astro.url.searchParams.get('next') ?? '/';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#080C14" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="apple-touch-icon" href="/logo.png" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;600;700&family=Quicksand:wght@500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <title>Digu League</title>
</head>
<body>

<!-- ═══ ANIMATED BACKGROUND ═══ -->
<canvas id="bg-canvas"></canvas>

<div class="bg-grad-1"></div>
<div class="bg-grad-2"></div>
<div class="bg-grad-3"></div>

<!-- ═══ MAIN PAGE ═══ -->
<div class="page">

  <!-- LOGO & TITLE -->
  <div class="brand">
    <!-- Decorative rings -->
    <div class="logo-stage">
      <div class="orbit orbit-1"></div>
      <div class="orbit orbit-2"></div>
      <div class="orbit orbit-3"></div>
      <div class="logo-glow"></div>
      <img src="/logo.png" alt="Digu League" class="brand-logo" id="brand-logo" />
      <!-- Crown sparkles -->
      <div class="sparkle sp1">✦</div>
      <div class="sparkle sp2">✦</div>
      <div class="sparkle sp3">✦</div>
      <div class="sparkle sp4">✦</div>
    </div>

    <div class="brand-text">
      <h1 class="brand-name">Digu League</h1>
      <div class="brand-rule">
        <span class="rule-line"></span>
        <span class="rule-suit">♦</span>
        <span class="rule-line"></span>
      </div>
      <p class="brand-motto">Play Smart &nbsp;·&nbsp; Win Big &nbsp;·&nbsp; Reign Supreme</p>
    </div>

    <!-- TROPHY SHOWCASE -->
    <div class="trophy-showcase">
      <div class="trophy-label">
        <span class="trophy-label-line"></span>
        <span class="trophy-label-text">🏆 MAY 2026 CHAMPION</span>
        <span class="trophy-label-line"></span>
      </div>
      <div class="trophy-img-wrap">
        <div class="trophy-ground-glow"></div>
        <img src="/badges/champion-may-2026.png" alt="May 2026 Champion Trophy" class="trophy-img" />
      </div>
      <div class="trophy-winner">
        <span class="trophy-crown">👑</span>
        <span class="trophy-winner-name">Mohamed Shujau</span>
      </div>
    </div>
  </div>

  <!-- LOGIN CARD -->
  <div class="lcard">

    <!-- Card shimmer effect -->
    <div class="card-shine"></div>

    <!-- Header -->
    <div class="lcard-header">
      <div class="lcard-suits">
        <span class="ls black">♠</span>
        <span class="ls red">♥</span>
        <span class="ls black">♣</span>
        <span class="ls red">♦</span>
      </div>
      <div class="lcard-title">Sign In</div>
    </div>

    <!-- Tabs -->
    <div class="ltabs">
      <button class="ltab ltab-active" id="tab-player" onclick="switchTab('player')">
        <span class="ltab-icon">🎴</span>
        <span class="ltab-label">Player</span>
        <div class="ltab-bar"></div>
      </button>
      <div class="ltab-divider">|</div>
      <button class="ltab" id="tab-admin" onclick="switchTab('admin')">
        <span class="ltab-icon">⚙️</span>
        <span class="ltab-label">Admin</span>
        <div class="ltab-bar"></div>
      </button>
    </div>

    <!-- Player panel -->
    <div id="panel-player">
      <div class="access-badge player-badge">
        <div class="ab-dot"></div>
        <span>Start matches · Enter scores · Edit rounds</span>
      </div>
      <form id="player-form">
        <input type="hidden" class="nxt" value={next} />
        <div class="lfield">
          <label class="llabel">Player Password</label>
          <div class="linput-wrap" id="pw-wrap-player">
            <span class="linput-icon">🔑</span>
            <input type="password" class="linput" id="player-pw"
              placeholder="Enter password"
              autocomplete="current-password"
              onfocus="document.getElementById('pw-wrap-player').classList.add('focused')"
              onblur="document.getElementById('pw-wrap-player').classList.remove('focused')" />
            <button type="button" class="leye" onclick="togglePw('player-pw',this)">👁</button>
          </div>
        </div>
        <p class="lerr" id="player-err"></p>
        <button type="submit" class="lbtn player-lbtn" id="player-sub">
          <span class="lbtn-text">Sign In as Player</span>
          <span class="lbtn-arrow">→</span>
        </button>
      </form>
    </div>

    <!-- Admin panel -->
    <div id="panel-admin" style="display:none">
      <div class="access-badge admin-badge">
        <div class="ab-dot ab-red"></div>
        <span>Full access · Manage players · All settings</span>
      </div>
      <form id="admin-form">
        <input type="hidden" class="nxt" value={next} />
        <div class="lfield">
          <label class="llabel">Admin Password</label>
          <div class="linput-wrap" id="pw-wrap-admin">
            <span class="linput-icon">🔐</span>
            <input type="password" class="linput" id="admin-pw"
              placeholder="Enter password"
              autocomplete="current-password"
              onfocus="document.getElementById('pw-wrap-admin').classList.add('focused')"
              onblur="document.getElementById('pw-wrap-admin').classList.remove('focused')" />
            <button type="button" class="leye" onclick="togglePw('admin-pw',this)">👁</button>
          </div>
        </div>
        <p class="lerr" id="admin-err"></p>
        <button type="submit" class="lbtn admin-lbtn" id="admin-sub">
          <span class="lbtn-text">Sign In as Admin</span>
          <span class="lbtn-arrow">→</span>
        </button>
      </form>
    </div>

  </div>

  <p class="footer-text">♠ ♥ ♣ ♦ &nbsp; Gin Rummy Competition Tracker</p>

</div>

<script>
  // Tab switching
  function switchTab(r) {
    const p = r === 'player';
    document.getElementById('panel-player').style.display = p ? '' : 'none';
    document.getElementById('panel-admin').style.display = p ? 'none' : '';
    document.getElementById('tab-player').classList.toggle('ltab-active', p);
    document.getElementById('tab-admin').classList.toggle('ltab-active', !p);
  }

  // Show/hide password
  function togglePw(id, btn) {
    const i = document.getElementById(id);
    i.type = i.type === 'password' ? 'text' : 'password';
    btn.textContent = i.type === 'password' ? '👁' : '🙈';
  }

  // Login logic
  async function doLogin(pw, next, errEl, btn) {
    errEl.textContent = '';
    btn.disabled = true;
    const orig = btn.innerHTML;
    btn.innerHTML = '<span class="lbtn-text">Signing in…</span>';
    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pw }),
      });
      if (res.ok) { window.location.href = next || '/'; }
      else {
        const d = await res.json();
        errEl.textContent = d.error || 'Incorrect password';
        btn.disabled = false;
        btn.innerHTML = orig;
      }
    } catch {
      errEl.textContent = 'Network error — please try again';
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  }

  document.getElementById('player-form').addEventListener('submit', e => {
    e.preventDefault();
    doLogin(document.getElementById('player-pw').value,
      e.currentTarget.querySelector('.nxt').value,
      document.getElementById('player-err'),
      document.getElementById('player-sub'));
  });
  document.getElementById('admin-form').addEventListener('submit', e => {
    e.preventDefault();
    doLogin(document.getElementById('admin-pw').value,
      e.currentTarget.querySelector('.nxt').value,
      document.getElementById('admin-err'),
      document.getElementById('admin-sub'));
  });

  // Canvas particle effect
  const canvas = document.getElementById('bg-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, particles = [];

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  // Create golden dust particles
  for (let i = 0; i < 60; i++) {
    particles.push({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      r: Math.random() * 1.5 + 0.3,
      dx: (Math.random() - 0.5) * 0.3,
      dy: -Math.random() * 0.4 - 0.1,
      o: Math.random() * 0.5 + 0.1,
      do: (Math.random() - 0.5) * 0.005,
    });
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    particles.forEach(p => {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(212,175,55,${p.o})`;
      ctx.fill();
      p.x += p.dx; p.y += p.dy;
      p.o += p.do;
      if (p.o < 0.05 || p.o > 0.6) p.do *= -1;
      if (p.y < -5) { p.y = H + 5; p.x = Math.random() * W; }
      if (p.x < -5) p.x = W + 5;
      if (p.x > W + 5) p.x = -5;
    });
    requestAnimationFrame(draw);
  }
  draw();
</script>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; }

body {
  font-family: 'Quicksand', system-ui, sans-serif;
  background: #080C14;
  color: #DDD1BF;
  min-height: 100dvh;
  overflow-x: hidden;
}

/* Canvas */
#bg-canvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; }

/* Background gradients */
.bg-grad-1, .bg-grad-2, .bg-grad-3 {
  position: fixed; border-radius: 50%; pointer-events: none; z-index: 0;
  filter: blur(100px);
}
.bg-grad-1 { width: 600px; height: 600px; top: -200px; left: -150px; background: rgba(212,175,55,0.05); animation: bg-drift 12s ease-in-out infinite alternate; }
.bg-grad-2 { width: 500px; height: 500px; bottom: -150px; right: -100px; background: rgba(200,16,46,0.05); animation: bg-drift 15s ease-in-out infinite alternate-reverse; }
.bg-grad-3 { width: 400px; height: 400px; top: 40%; left: 30%; background: rgba(43,79,55,0.06); animation: bg-drift 10s ease-in-out infinite alternate; }
@keyframes bg-drift { from { transform: translate(0,0) scale(1); } to { transform: translate(30px,20px) scale(1.1); } }

  50%,85%     { transform: rotateY(180deg); }
}

/* ═══ PAGE ═══ */
html, body { min-height: 100dvh; width: 100%; }

.page {
  position: relative; z-index: 10;
  min-height: 100dvh; width: 100%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 2rem 1.25rem 2.5rem;
  gap: 1.5rem;
  box-sizing: border-box;
}

/* ═══ BRAND ═══ */
.brand { text-align: center; }

/* Logo stage */
.logo-stage {
  position: relative; width: 150px; height: 150px;
  margin: 0 auto 1.25rem;
}

/* Orbiting rings */
.orbit {
  position: absolute; border-radius: 50%; pointer-events: none;
  border-style: solid;
}
.orbit-1 {
  inset: -14px;
  border-width: 1.5px;
  border-color: rgba(212,175,55,0.35) rgba(212,175,55,0.1) rgba(212,175,55,0.35) rgba(212,175,55,0.1);
  animation: orbit-spin 6s linear infinite;
}
.orbit-2 {
  inset: -24px;
  border-width: 1px;
  border-color: rgba(200,16,46,0.2) transparent rgba(200,16,46,0.2) transparent;
  animation: orbit-spin 10s linear infinite reverse;
}
.orbit-3 {
  inset: -34px;
  border-width: 0.5px;
  border-color: rgba(212,175,55,0.1) transparent rgba(212,175,55,0.1) transparent;
  animation: orbit-spin 16s linear infinite;
}
@keyframes orbit-spin { to { transform: rotate(360deg); } }

/* Glow */
.logo-glow {
  position: absolute; inset: -25px; border-radius: 50%;
  background: radial-gradient(circle, rgba(212,175,55,0.22) 0%, transparent 70%);
  animation: logo-breathe 3s ease-in-out infinite;
  pointer-events: none;
}
@keyframes logo-breathe {
  0%,100% { transform: scale(1);   opacity: 0.8; }
  50%      { transform: scale(1.2); opacity: 1;   }
}

.brand-logo {
  width: 150px; height: 150px; border-radius: 22px;
  position: relative; z-index: 2; object-fit: cover;
  box-shadow:
    0 0 0 2px rgba(212,175,55,0.5),
    0 0 0 4px rgba(212,175,55,0.12),
    0 20px 60px rgba(0,0,0,0.8),
    0 0 60px rgba(212,175,55,0.25);
  animation: logo-levitate 4s ease-in-out infinite;
}

/* Desktop: side by side layout */
@media (min-width: 800px) {
  .page {
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 5rem;
    padding: 2rem 3rem;
  }
  .brand { text-align: center; flex-shrink: 0; }
  .lcard { max-width: 420px; }
  .footer-text { position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%); }
}
@keyframes logo-levitate {
  0%,100% { transform: translateY(0);    box-shadow: 0 0 0 2px rgba(212,175,55,0.4), 0 20px 60px rgba(0,0,0,.8), 0 0 60px rgba(212,175,55,.2); }
  50%      { transform: translateY(-8px); box-shadow: 0 0 0 2px rgba(212,175,55,0.6), 0 28px 70px rgba(0,0,0,.7), 0 0 80px rgba(212,175,55,.35); }
}

/* Sparkles */
.sparkle {
  position: absolute; z-index: 3; color: #D4AF37;
  font-size: 0.875rem; pointer-events: none;
  animation: sparkle-pulse 2s ease-in-out infinite;
}
.sp1 { top:-8px;  left:50%; transform:translateX(-50%); animation-delay:0s; }
.sp2 { top:50%;   right:-10px; transform:translateY(-50%); animation-delay:0.5s; }
.sp3 { bottom:-8px; left:50%; transform:translateX(-50%); animation-delay:1s; }
.sp4 { top:50%;   left:-10px; transform:translateY(-50%); animation-delay:1.5s; }
@keyframes sparkle-pulse {
  0%,100% { opacity:0.3; transform:scale(0.8) translateX(-50%); }
  50%      { opacity:1;   transform:scale(1.3) translateX(-50%); }
}
.sp2, .sp4 { transform: translateY(-50%) !important; }
@keyframes sparkle-pulse2 {
  0%,100% { opacity:0.3; transform:scale(0.8) translateY(-50%); }
  50%      { opacity:1;   transform:scale(1.3) translateY(-50%); }
}
.sp2 { animation-name: sparkle-pulse2; }
.sp4 { animation-name: sparkle-pulse2; }

/* Brand text */
.brand-text { text-align: center; }

.brand-name {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(1.75rem, 7vw, 2.5rem);
  font-weight: 900; color: #D4AF37;
  letter-spacing: 0.04em; line-height: 1.1;
  text-shadow:
    0 0 30px rgba(212,175,55,0.5),
    0 0 60px rgba(212,175,55,0.2),
    0 2px 4px rgba(0,0,0,0.8);
  animation: name-glow 4s ease-in-out infinite;
  margin-bottom: 0.75rem;
}
@keyframes name-glow {
  0%,100% { text-shadow: 0 0 30px rgba(212,175,55,0.5), 0 0 60px rgba(212,175,55,0.2), 0 2px 4px rgba(0,0,0,.8); }
  50%      { text-shadow: 0 0 40px rgba(212,175,55,0.7), 0 0 80px rgba(212,175,55,0.35), 0 2px 4px rgba(0,0,0,.8); }
}

.brand-rule {
  display: flex; align-items: center; justify-content: center;
  gap: 0.625rem; margin-bottom: 0.625rem;
}
.rule-line {
  height: 1px; width: 50px;
  background: linear-gradient(90deg, transparent, rgba(212,175,55,0.5), transparent);
}
.rule-suit { color: #D4AF37; font-size: 0.75rem; opacity: 0.7; }

.brand-motto {
  font-family: 'Cormorant Garamond', serif;
  font-size: 0.75rem; font-weight: 600;
  color: rgba(212,175,55,0.6);
  letter-spacing: 0.18em; text-transform: uppercase;
  font-style: italic;
}

/* ═══ LOGIN CARD ═══ */
.lcard {
  width: 100%; max-width: 400px;
  background: linear-gradient(160deg, #0F1828 0%, #090E1C 100%);
  border: 1.5px solid rgba(212,175,55,0.45);
  border-radius: 22px;
  padding: 1.875rem 1.75rem 2rem;
  position: relative; overflow: hidden;
  box-shadow:
    0 0 0 1px rgba(212,175,55,0.08),
    0 0 60px rgba(212,175,55,0.12),
    0 30px 80px rgba(0,0,0,0.8),
    inset 0 1px 0 rgba(255,255,255,0.06),
    inset 0 -1px 0 rgba(212,175,55,0.05);
  animation: card-in 0.7s cubic-bezier(0.34,1.56,0.64,1) both 0.2s;
}
@keyframes card-in {
  from { opacity:0; transform: translateY(40px) scale(0.94); }
  to   { opacity:1; transform: none; }
}

/* Shimmer sweep */
.card-shine {
  position: absolute; top: 0; left: -100%;
  width: 60%; height: 100%;
  background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.03) 50%, transparent 60%);
  animation: shine-sweep 4s ease-in-out infinite 1s;
  pointer-events: none;
}
@keyframes shine-sweep { 0%,100% { left:-100%; } 50% { left:150%; } }

/* Card header */
.lcard-header {
  display: flex; align-items: center; gap: 0.75rem;
  margin-bottom: 1.25rem;
}
.lcard-suits { display: flex; gap: 0.3rem; }
.ls { font-size: 0.9375rem; font-family: Georgia, serif; opacity: 0.6; }
.ls.black { color: #DDD1BF; }
.ls.red   { color: #C8102E; }
.lcard-title {
  font-family: 'Cinzel', serif;
  font-size: 1.0625rem; font-weight: 700; color: #DDD1BF;
  letter-spacing: 0.1em; text-transform: uppercase;
}

/* Tabs */
.ltabs {
  display: flex; align-items: center;
  gap: 0; margin-bottom: 1.25rem;
  border-bottom: 1px solid rgba(212,175,55,0.12);
  padding-bottom: 0;
}
.ltab {
  flex: 1; display: flex; align-items: center; justify-content: center;
  gap: 0.5rem; padding: 0.625rem 0.5rem 0.75rem;
  font-size: 0.9375rem; font-weight: 700; cursor: pointer;
  color: rgba(200,180,140,0.4); transition: all 0.2s;
  font-family: 'Quicksand', sans-serif;
  position: relative;
}
.ltab-bar {
  position: absolute; bottom: -1px; left: 10%; right: 10%; height: 2px;
  background: linear-gradient(90deg, transparent, #D4AF37, transparent);
  border-radius: 2px; opacity: 0;
  box-shadow: 0 0 8px rgba(212,175,55,0.6);
  transition: opacity 0.2s;
}
.ltab-active { color: #D4AF37; }
.ltab-active .ltab-bar { opacity: 1; }
.ltab-divider { color: rgba(212,175,55,0.15); font-size: 1.25rem; padding: 0 0.25rem; }
.ltab-icon { font-size: 1rem; }
.ltab-label { font-size: 0.875rem; }

/* Access badge */
.access-badge {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 0.6rem 0.875rem; border-radius: 10px;
  margin-bottom: 1.125rem;
  font-size: 0.75rem; font-weight: 600; color: rgba(200,180,140,0.6);
}
.player-badge { background: rgba(212,175,55,0.05); border: 1px solid rgba(212,175,55,0.12); }
.admin-badge  { background: rgba(120,39,13,0.08);  border: 1px solid rgba(120,39,13,0.22); }
.ab-dot {
  width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
  background: #D4AF37; box-shadow: 0 0 6px rgba(212,175,55,0.6);
  animation: dot-pulse 2s ease-in-out infinite;
}
.ab-dot.ab-red { background: #C8102E; box-shadow: 0 0 6px rgba(200,16,46,0.6); }
@keyframes dot-pulse { 0%,100% { transform:scale(1); opacity:1; } 50% { transform:scale(1.3); opacity:0.8; } }

/* Field */
.lfield { margin-bottom: 0.875rem; }
.llabel {
  display: block; font-size: 0.5625rem; font-weight: 800;
  text-transform: uppercase; letter-spacing: 0.16em;
  color: rgba(200,180,140,0.5); margin-bottom: 0.5rem;
  font-family: 'Cinzel', serif;
}
.linput-wrap {
  display: flex; align-items: center;
  background: rgba(0,0,0,0.4);
  border: 1.5px solid rgba(212,175,55,0.12);
  border-radius: 12px; overflow: hidden;
  transition: all 0.25s;
}
.linput-wrap.focused {
  border-color: rgba(212,175,55,0.45);
  box-shadow: 0 0 0 3px rgba(212,175,55,0.07), 0 0 16px rgba(212,175,55,0.08);
  background: rgba(0,0,0,0.5);
}
.linput-icon { padding: 0 0.875rem; font-size: 1rem; flex-shrink: 0; }
.linput {
  flex: 1; background: none; border: none; outline: none;
  color: #E8D8B8; font-size: 1rem; font-family: 'Quicksand', sans-serif;
  padding: 0.8125rem 0; font-weight: 600; min-width: 0; letter-spacing: 0.05em;
}
.linput::placeholder { color: rgba(200,180,140,0.2); letter-spacing: 0; }
.leye { padding: 0 0.875rem; font-size: 1rem; cursor: pointer; color: rgba(200,180,140,0.4); flex-shrink: 0; transition: color 0.15s; }
.leye:hover { color: #D4AF37; }

/* Error */
.lerr {
  font-size: 0.8125rem; color: #C8102E; font-weight: 700;
  min-height: 1.25em; margin-bottom: 0.625rem;
  font-family: 'Quicksand', sans-serif;
}

/* Submit buttons */
.lbtn {
  width: 100%; padding: 1rem; border-radius: 12px; border: none;
  font-size: 1rem; font-weight: 800; cursor: pointer;
  font-family: 'Quicksand', sans-serif;
  transition: all 0.25s; min-height: 54px;
  display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  position: relative; overflow: hidden;
}
.lbtn::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.1) 0%, transparent 50%);
  pointer-events: none;
}
.lbtn-text { flex: 1; text-align: center; }
.lbtn-arrow { font-size: 1.125rem; transition: transform 0.2s; }
.lbtn:hover .lbtn-arrow { transform: translateX(4px); }

.player-lbtn {
  background: linear-gradient(135deg, #9A7800, #C8A400, #D4AF37, #E8CC60, #D4AF37);
  background-size: 200% 100%;
  color: #1A1200;
  box-shadow: 0 6px 28px rgba(212,175,55,0.45), 0 2px 8px rgba(0,0,0,0.4);
  animation: btn-shimmer 3s linear infinite;
}
@keyframes btn-shimmer { 0% { background-position: 0% 0%; } 100% { background-position: 200% 0%; } }
.player-lbtn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 10px 36px rgba(212,175,55,0.6), 0 2px 8px rgba(0,0,0,0.4);
}

.admin-lbtn {
  background: linear-gradient(135deg, #4A0F04, #78270D, #A03418);
  color: #FFD8C0;
  box-shadow: 0 6px 28px rgba(120,39,13,0.55), 0 2px 8px rgba(0,0,0,0.4);
}
.admin-lbtn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 10px 36px rgba(120,39,13,0.7), 0 2px 8px rgba(0,0,0,0.4);
}

.lbtn:active { transform: translateY(0) !important; }
.lbtn:disabled { opacity: 0.55; cursor: not-allowed; transform: none !important; }

/* Footer */
/* ═══ TROPHY SHOWCASE ═══ */
.trophy-showcase {
  margin-top: 1.25rem;
  display: flex; flex-direction: column; align-items: center; gap: 0.75rem;
}

.trophy-label {
  display: flex; align-items: center; gap: 0.625rem;
}
.trophy-label-line {
  height: 1px; width: 40px;
  background: linear-gradient(90deg, transparent, rgba(212,175,55,0.5));
}
.trophy-label-line:last-child {
  background: linear-gradient(90deg, rgba(212,175,55,0.5), transparent);
}
.trophy-label-text {
  font-family: 'Cinzel', serif;
  font-size: 0.5625rem; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(212,175,55,0.65);
  white-space: nowrap;
}

.trophy-img-wrap {
  position: relative;
  display: flex; justify-content: center; align-items: flex-end;
  animation: trophy-hover 4s ease-in-out infinite;
}
.trophy-ground-glow {
  position: absolute; bottom: -4px; left: 50%;
  transform: translateX(-50%);
  width: 120px; height: 16px;
  background: radial-gradient(ellipse, rgba(212,175,55,0.5) 0%, transparent 70%);
  filter: blur(6px);
  animation: glow-pulse 4s ease-in-out infinite;
}
.trophy-img {
  width: 160px; height: auto;
  display: block; position: relative; z-index: 1;
  mix-blend-mode: multiply;
  filter:
    drop-shadow(0 0 16px rgba(212,175,55,0.7))
    drop-shadow(0 0 32px rgba(212,175,55,0.35))
    drop-shadow(0 12px 24px rgba(0,0,0,0.8));
}
@keyframes trophy-hover {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-10px); }
}
@keyframes glow-pulse {
  0%,100% { opacity: 0.6; transform: translateX(-50%) scaleX(0.9); }
  50%      { opacity: 1;   transform: translateX(-50%) scaleX(1.2); }
}

.trophy-winner {
  display: flex; align-items: center; gap: 0.5rem;
  background: linear-gradient(135deg, rgba(212,175,55,0.1), rgba(212,175,55,0.06));
  border: 1px solid rgba(212,175,55,0.3);
  border-radius: 30px; padding: 0.4rem 1rem;
}
.trophy-crown { font-size: 0.875rem; }
.trophy-winner-name {
  font-family: 'Cinzel', serif;
  font-size: 0.75rem; font-weight: 700;
  color: #D4AF37; letter-spacing: 0.06em;
}

/* Desktop: trophy below brand text, all in left column */
@media (min-width: 800px) {
  .trophy-img { width: 180px; }
}

/* Mobile: smaller trophy */
@media (max-width: 480px) {
  .trophy-img { width: 130px; }
}

.footer-text {
  font-size: 0.6875rem; color: rgba(212,175,55,0.25);
  letter-spacing: 0.12em; font-family: 'Cinzel', serif;
  text-transform: uppercase;
}
