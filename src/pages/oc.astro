---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import { computeOCChampions } from '../lib/db';

const db = (Astro.locals as any).runtime?.env?.DB as D1Database;

const nowMonth = new Date().toISOString().slice(0, 7);
const selectedMonth = Astro.url.searchParams.get('month') || undefined; // history: view a past month

let month = selectedMonth || nowMonth;
let qualMonth = '';
let qualifiers: { player_id: string; name: string; nickname: string | null; avatar_b64: string | null; league_points: number; rank: number }[] = [];
let standings: { player_id: string; name: string; nickname: string | null; avatar_b64: string | null; matches_played: number; matches_won: number; matches_drawn: number; matches_lost: number; champions_points: number }[] = [];
let started = false;
try {
  const res = await computeOCChampions(db, selectedMonth);
  month = res.month;
  qualMonth = res.qualMonth;
  qualifiers = res.qualifiers;
  standings = res.standings;
  started = res.started;
} catch (e) {
  // fall through with empty data
}

const fmtMonth = (ym: string) => {
  const [yy, mm] = ym.split('-');
  return new Date(Number(yy), Number(mm) - 1, 1).toLocaleString('en-US', { month: 'long', year: 'numeric' });
};
// Ongoing-month label (scores) + last-month label (qualification)
const monthLabel = fmtMonth(month);
const qualMonthLabel = qualMonth ? fmtMonth(qualMonth) : '';
// Status of the viewed month relative to the ongoing (current) month
const status: 'ongoing' | 'finished' | 'upcoming' =
  month === nowMonth ? 'ongoing' : (month < nowMonth ? 'finished' : 'upcoming');

// Browse: 2 upcoming months + this month + past 11 (most recent first)
const monthOptions: { value: string; label: string }[] = [];
{
  let [oy, om] = nowMonth.split('-').map(Number);
  om += 2; while (om > 12) { om -= 12; oy += 1; } // start 2 months ahead
  for (let i = 0; i < 14; i++) {
    const v = `${oy}-${String(om).padStart(2, '0')}`;
    monthOptions.push({ value: v, label: fmtMonth(v) });
    om -= 1; if (om === 0) { om = 12; oy -= 1; }
  }
}

const MEDAL_COLOR = ['#D4AF37', '#C0C0C0', '#CD7F32'];

function initials(name: string) {
  return name.split(' ').map((w) => w[0]).join('').slice(0, 2).toUpperCase();
}
---

<BaseLayout title="OC Champions League" activeTab="leaderboard">
  <div class="container">
    <!-- Hero -->
    <div class="oc-hero">
      <h1 class="oc-title">🏆 OC Champions League</h1>
      <div class="oc-month-row">
        <select class="oc-month-sel" aria-label="Select month" onchange="location.href='/oc?month='+this.value">
          {monthOptions.map((o) => <option value={o.value} selected={o.value === month}>{o.label}</option>)}
        </select>
        {status === 'ongoing' && <span class="oc-live oc-live-on">● Ongoing</span>}
        {status === 'finished' && <span class="oc-live oc-live-done">✓ Finished</span>}
        {status === 'upcoming' && <span class="oc-live oc-live-soon">◷ Upcoming</span>}
      </div>
      <p class="oc-note">Top 5 players · Win +3 · Loss −1 · New tournament every month</p>
      <button id="oc-share-btn" class="oc-share-btn" type="button">📤 Share</button>
      <span id="oc-share-toast" class="oc-share-toast">Link copied</span>
    </div>

    {qualifiers.length === 0 ? (
      <div class="empty-state">
        <div style="font-size:2.5rem;margin-bottom:0.5rem;">🃏</div>
        <p>No qualifiers yet — the top 5 come from last month's league standings.</p>
      </div>
    ) : (
      <>
        <div class="oc-qual-label">Qualified players · top 5 from {qualMonthLabel}</div>
        <div class="oc-qual-strip">
          {qualifiers.map((q) => (
            <div class="oc-qual-chip">
              <span class="oc-qual-rank" style={`color:${MEDAL_COLOR[q.rank - 1] ?? 'var(--text-muted)'};border-color:${MEDAL_COLOR[q.rank - 1] ?? 'rgba(255,255,255,0.2)'}`}>{q.rank}</span>
              {q.avatar_b64 ? (
                <img class="oc-qual-avatar" src={`data:image/jpeg;base64,${q.avatar_b64}`} alt={q.name} />
              ) : (
                <span class="oc-qual-avatar oc-qual-avatar-fb">{initials(q.name)}</span>
              )}
              <span class="oc-qual-name">{q.nickname || q.name}</span>
              <span class="oc-qual-pts">{q.league_points} pts</span>
            </div>
          ))}
        </div>

        {!started && (
          <p class="oc-caption">This month's tournament hasn't started yet — standings seed all qualifiers at 0 pts.</p>
        )}

        <div class="lb-table-wrap">
          <table class="lb-table">
            <thead>
              <tr>
                <th style="width:40px;">#</th>
                <th style="text-align:left;">Player</th>
                <th title="Champions Points">PTS</th>
                <th title="Matches Played">GP</th>
                <th title="Wins">W</th>
                <th title="Draws">D</th>
                <th title="Losses">L</th>
              </tr>
            </thead>
            <tbody>
              {standings.map((s, i) => (
                <tr class={`lb-row ${i < 3 ? `top-${i + 1}` : ''}`}>
                  <td class="rank-cell">
                    {i < 3 ? (
                      <div class="rank-medal" style={`border-color:${MEDAL_COLOR[i]};color:${MEDAL_COLOR[i]};box-shadow:0 0 10px ${MEDAL_COLOR[i]}44`}>{i + 1}</div>
                    ) : <span class="rank-num">{i + 1}</span>}
                  </td>
                  <td>
                    <div class="player-cell">
                      {s.avatar_b64 ? (
                        <img class="player-avatar" src={`data:image/jpeg;base64,${s.avatar_b64}`} alt={s.name} style={i < 3 ? `border-color:${MEDAL_COLOR[i]};box-shadow:0 0 12px ${MEDAL_COLOR[i]}66` : ''} />
                      ) : (
                        <span class="player-avatar player-avatar-fb" style={i < 3 ? `border-color:${MEDAL_COLOR[i]};box-shadow:0 0 12px ${MEDAL_COLOR[i]}66` : ''}>{initials(s.name)}</span>
                      )}
                      <div>
                        <div class="player-name">{s.nickname || s.name}</div>
                        <div class="player-nick">{s.name}</div>
                      </div>
                    </div>
                  </td>
                  <td><span class="stat-val pts">{s.champions_points}</span></td>
                  <td><span class="stat-val">{s.matches_played}</span></td>
                  <td><span class="stat-val win">{s.matches_won}</span></td>
                  <td><span class="stat-val">{s.matches_drawn}</span></td>
                  <td><span class="stat-val loss">{s.matches_lost}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </>
    )}
  </div>
</BaseLayout>

<style>
  /* Hero */
  .oc-hero {
    text-align: center;
    padding: 1.25rem 0 0.5rem;
    margin-bottom: 1rem;
  }
  .oc-title {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--gold);
    margin: 0 0 0.25rem;
    text-shadow: 0 0 18px rgba(212,175,55,0.25);
  }
  .oc-month-row { display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin: 0 0 0.375rem; flex-wrap: wrap; }
  .oc-month-sel {
    font-family: inherit; font-size: 1.0625rem; font-weight: 800; color: var(--gold);
    background: rgba(212,175,55,0.06); border: 1.5px solid rgba(212,175,55,0.4);
    border-radius: 10px; padding: 0.3rem 0.7rem; cursor: pointer; letter-spacing: 0.02em;
  }
  .oc-month-sel:hover { background: rgba(212,175,55,0.14); }
  .oc-live { font-size: 0.6875rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; white-space: nowrap; }
  .oc-live-on { color: #3FB950; }
  .oc-live-done { color: var(--text-muted); }
  .oc-live-soon { color: #58A6FF; }
  .oc-note {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    margin: 0;
    letter-spacing: 0.02em;
  }
  .oc-share-btn {
    margin-top: 0.875rem;
    padding: 0.5rem 1.125rem;
    border-radius: 99px;
    font-size: 0.8125rem;
    font-weight: 700;
    font-family: inherit;
    border: 1.5px solid var(--gold);
    color: var(--gold);
    background: rgba(212,175,55,0.08);
    cursor: pointer;
    transition: all 0.15s;
  }
  .oc-share-btn:hover { background: rgba(212,175,55,0.18); box-shadow: 0 0 14px rgba(212,175,55,0.2); }
  .oc-share-toast {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--felt-light);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .oc-share-toast.show { opacity: 1; }

  /* Qualified players strip */
  .oc-qual-label {
    font-size: 0.625rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.5rem;
  }
  .oc-qual-strip {
    display: flex; gap: 0.5rem; overflow-x: auto; -webkit-overflow-scrolling: touch;
    padding-bottom: 0.25rem; margin-bottom: 1rem;
  }
  .oc-qual-chip {
    display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(212,175,55,0.25);
    border-radius: 12px; padding: 0.5rem 0.75rem;
  }
  .oc-qual-rank {
    width: 22px; height: 22px; border-radius: 50%; border: 2px solid;
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 0.75rem; flex-shrink: 0;
  }
  .oc-qual-avatar {
    width: 30px; height: 30px; border-radius: 50%; object-fit: cover;
    border: 2px solid rgba(255,255,255,0.1); flex-shrink: 0;
  }
  .oc-qual-avatar-fb {
    display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #2B4F37, #1a3123);
    color: var(--cream, #DDD1BF); font-weight: 800; font-size: 0.6875rem;
    letter-spacing: -0.5px;
  }
  .oc-qual-name { font-weight: 700; font-size: 0.875rem; color: var(--text-primary); white-space: nowrap; }
  .oc-qual-pts { font-size: 0.75rem; font-weight: 600; color: var(--felt-light); white-space: nowrap; }

  .oc-caption {
    font-size: 0.75rem; color: var(--text-muted); text-align: center;
    margin: 0 0 0.875rem; font-style: italic;
  }

  /* ── Table — mirrors league PLAYER table (LeaderboardTable.tsx) ── */
  .lb-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; border-radius: 16px; border: 1.5px solid rgba(212,175,55,0.4); box-shadow: 0 0 20px rgba(212,175,55,0.1), inset 0 1px 0 rgba(212,175,55,0.06); }
  .lb-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .lb-table thead { background: rgba(255,255,255,0.04); }
  .lb-table th {
    padding: 0.75rem 0.5rem; text-align: center;
    font-size: 0.625rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-muted);
    border-bottom: 1px solid rgba(255,255,255,0.07); white-space: nowrap;
  }

  .lb-row td { padding: 0.625rem 0.5rem; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.12s; }
  .lb-row:hover td { background: rgba(255,255,255,0.03); }
  .lb-row:last-child td { border-bottom: none; }
  .top-1 td { background: rgba(212,175,55,0.06); }
  .top-2 td { background: rgba(192,192,192,0.04); }
  .top-3 td { background: rgba(205,127,50,0.04); }
  .top-1:hover td { background: rgba(212,175,55,0.1); }

  /* Rank cells */
  .rank-cell { text-align: center !important; }
  .rank-medal {
    width: 28px; height: 28px; border-radius: 50%; border: 2px solid;
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 0.8125rem; margin: 0 auto;
  }
  .rank-num { color: var(--text-muted); font-weight: 700; font-size: 0.8125rem; }

  /* Player cell */
  .player-cell {
    display: flex; align-items: center; gap: 0.5rem;
    text-decoration: none; color: inherit; text-align: left;
  }
  .player-avatar {
    width: 34px; height: 34px; border-radius: 50%; object-fit: cover;
    border: 2px solid rgba(255,255,255,0.1); flex-shrink: 0;
  }
  .player-avatar-fb {
    display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #2B4F37, #1a3123);
    color: var(--cream, #DDD1BF); font-weight: 800; font-size: 0.75rem;
    letter-spacing: -0.5px; box-shadow: 0 2px 8px rgba(0,0,0,0.4);
  }
  .player-name { font-weight: 700; font-size: 0.9375rem; color: var(--text-primary); white-space: nowrap; }
  .player-nick { font-size: 0.75rem; color: var(--felt-light); font-weight: 600; }

  /* Stat values */
  .stat-val { font-weight: 700; font-size: 0.875rem; color: var(--text-primary); }
  .stat-val.win { color: var(--felt-light); }
  .stat-val.loss { color: var(--ember); }
  .stat-val.pts { color: var(--gold); font-size: 1rem; }

  .empty-state { text-align: center; padding: 3rem 1rem; color: var(--text-muted); }
  .empty-state p { font-size: 0.9375rem; }

  @media (max-width: 768px) {
    .lb-table-wrap { border-radius: 12px; width: 100%; }
    .lb-table { font-size: 0.75rem; table-layout: fixed; width: 100%; }
    .lb-table th { padding: 0.5rem 0.15rem; font-size: 0.5625rem; letter-spacing: 0.04em; }
    .lb-table td { padding: 0.5rem 0.15rem; }
    .lb-table th:first-child, .lb-table td:first-child { width: 12% !important; }
    .lb-table th:nth-child(2), .lb-table td:nth-child(2) { width: 34% !important; text-align: left; overflow: hidden; }
    .player-cell { gap: 5px !important; align-items: center !important; overflow: hidden; }
    .player-avatar { width: 28px !important; height: 28px !important; font-size: 0.5rem !important; flex-shrink: 0; }
    .player-name { font-size: 0.6875rem !important; white-space: normal; overflow: hidden; text-overflow: clip; max-width: 68px; line-height: 1.25; word-break: break-word; font-weight: 700; }
    .player-nick { display: none !important; }
    .stat-val { font-size: 0.8125rem !important; font-weight: 700; }
    .rank-num { font-size: 0.6875rem !important; }
    .rank-medal { width: 24px !important; height: 24px !important; font-size: 0.6875rem !important; }
  }
</style>

<script define:vars={{ ocShare: { monthLabel, qualMonthLabel, rows: standings.map((s) => ({ name: s.nickname || s.name, pts: s.champions_points, gp: s.matches_played, w: s.matches_won, d: s.matches_drawn, l: s.matches_lost })) } }}>
  (function () {
    var btn = document.getElementById('oc-share-btn');
    var toast = document.getElementById('oc-share-toast');
    if (!btn) return;

    function flashToast(msg) {
      if (!toast) return;
      toast.textContent = msg;
      toast.classList.add('show');
      setTimeout(function () { toast.classList.remove('show'); }, 2000);
    }

    // Draw the Champions League standings as a PNG (matches the league image style)
    function buildOcImage() {
      var rows = ocShare.rows || [];
      var MEDAL = ['#D4AF37', '#A8A9AD', '#CD7F32'];
      var MEDAL_BG = ['rgba(212,175,55,0.13)', 'rgba(168,169,173,0.08)', 'rgba(205,127,50,0.09)'];
      var W = 680;
      var HEADER_H = 128;
      var COL_H = 30;
      var ROW_H = 56;
      var FOOTER_H = 46;
      var H = HEADER_H + COL_H + rows.length * ROW_H + FOOTER_H;
      var COL = { rank: 40, name: 84, pts: 380, gp: 448, w: 512, d: 568, l: 632 };

      var canvas = document.createElement('canvas');
      canvas.width = W; canvas.height = H;
      var ctx = canvas.getContext('2d');

      // Base felt-green background
      ctx.fillStyle = '#0A2A20';
      ctx.fillRect(0, 0, W, H);

      // Header band gradient
      var hg = ctx.createLinearGradient(0, 0, W, HEADER_H);
      hg.addColorStop(0, '#0B3D2E'); hg.addColorStop(0.5, '#082018'); hg.addColorStop(1, '#0B3D2E');
      ctx.fillStyle = hg; ctx.fillRect(0, 0, W, HEADER_H);

      // Gold top accent bar
      var topBar = ctx.createLinearGradient(0, 0, W, 0);
      topBar.addColorStop(0, 'transparent'); topBar.addColorStop(0.25, '#D4AF37');
      topBar.addColorStop(0.75, '#D4AF37'); topBar.addColorStop(1, 'transparent');
      ctx.fillStyle = topBar; ctx.fillRect(0, 0, W, 4);

      // Title + subtitle + qualification line
      ctx.textAlign = 'center';
      ctx.fillStyle = '#D4AF37';
      ctx.font = 'bold 27px system-ui, sans-serif';
      ctx.fillText('🏆 OC CHAMPIONS LEAGUE', W / 2, 46);
      ctx.fillStyle = '#DDD1BF';
      ctx.font = '600 14px system-ui, sans-serif';
      ctx.fillText(ocShare.monthLabel + ' · Top 5 · Win +3 · Loss −1', W / 2, 72);
      if (ocShare.qualMonthLabel) {
        ctx.fillStyle = '#638D6F';
        ctx.font = '700 11px system-ui, sans-serif';
        ctx.fillText('Qualified from ' + ocShare.qualMonthLabel, W / 2, 94);
      }
      ctx.strokeStyle = '#D4AF37'; ctx.globalAlpha = 0.3; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(60, 108); ctx.lineTo(W - 60, 108); ctx.stroke(); ctx.globalAlpha = 1;

      // Column header row
      ctx.fillStyle = 'rgba(255,255,255,0.04)'; ctx.fillRect(0, HEADER_H, W, COL_H);
      ctx.fillStyle = '#8AA595'; ctx.font = '700 10px system-ui, sans-serif';
      ctx.textAlign = 'left'; ctx.fillText('PLAYER', COL.name, HEADER_H + 20);
      ctx.textAlign = 'center';
      var heads = [['PTS', COL.pts], ['GP', COL.gp], ['W', COL.w], ['D', COL.d], ['L', COL.l]];
      for (var hI = 0; hI < heads.length; hI++) {
        ctx.fillText(heads[hI][0], heads[hI][1], HEADER_H + 20);
      }

      // Player rows
      rows.forEach(function (s, i) {
        var y = HEADER_H + COL_H + i * ROW_H;
        var cy = y + ROW_H / 2;
        var isTop3 = i < 3;

        ctx.fillStyle = isTop3 ? MEDAL_BG[i] : (i % 2 === 0 ? 'rgba(255,255,255,0.015)' : 'transparent');
        ctx.fillRect(0, y, W, ROW_H);
        if (isTop3) { ctx.fillStyle = MEDAL[i]; ctx.fillRect(0, y, 3, ROW_H); }
        ctx.strokeStyle = 'rgba(255,255,255,0.05)'; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(0, y + ROW_H - 1); ctx.lineTo(W, y + ROW_H - 1); ctx.stroke();

        // Rank chip
        ctx.textAlign = 'center';
        if (isTop3) {
          ctx.beginPath(); ctx.arc(COL.rank, cy, 15, 0, Math.PI * 2);
          ctx.fillStyle = MEDAL[i] + '33'; ctx.fill();
          ctx.strokeStyle = MEDAL[i]; ctx.lineWidth = 2; ctx.stroke();
          ctx.fillStyle = MEDAL[i]; ctx.font = 'bold 14px system-ui, sans-serif';
          ctx.fillText(String(i + 1), COL.rank, cy + 5);
        } else {
          ctx.fillStyle = '#6E8577'; ctx.font = '700 13px system-ui, sans-serif';
          ctx.fillText(String(i + 1), COL.rank, cy + 5);
        }

        // Player name
        ctx.textAlign = 'left';
        ctx.fillStyle = isTop3 ? '#ffffff' : '#DDD1BF';
        ctx.font = isTop3 ? '700 15px system-ui, sans-serif' : '600 14px system-ui, sans-serif';
        ctx.fillText(String(s.name), COL.name, cy + 5);

        // Stats
        ctx.textAlign = 'center';
        ctx.fillStyle = '#D4AF37'; ctx.font = isTop3 ? 'bold 16px system-ui, sans-serif' : 'bold 14px system-ui, sans-serif';
        ctx.fillText(String(s.pts), COL.pts, cy + 5);
        ctx.fillStyle = '#aaa'; ctx.font = '700 13px system-ui, sans-serif';
        ctx.fillText(String(s.gp), COL.gp, cy + 5);
        ctx.fillStyle = '#638D6F'; ctx.fillText(String(s.w), COL.w, cy + 5);
        ctx.fillStyle = '#aaa'; ctx.fillText(String(s.d), COL.d, cy + 5);
        ctx.fillStyle = '#C8102E'; ctx.fillText(String(s.l), COL.l, cy + 5);
      });

      // Footer
      ctx.textAlign = 'center';
      ctx.fillStyle = '#D4AF37'; ctx.globalAlpha = 0.85;
      ctx.font = '700 12px system-ui, sans-serif';
      ctx.fillText('♠ DIGU LEAGUE · OC Champions League ♠', W / 2, H - FOOTER_H / 2 + 4);
      ctx.globalAlpha = 1;

      return new Promise(function (resolve) {
        canvas.toBlob(function (b) { resolve(b); }, 'image/png');
      });
    }

    function fallbackLinkShare() {
      var shareData = {
        title: 'OC Champions League — Digu League',
        text: '🏆 OC Champions League standings',
        url: location.href,
      };
      if (navigator.share) {
        navigator.share(shareData).catch(function () {});
      } else if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(location.href).then(function () {
          flashToast('Link copied');
        }).catch(function () {});
      } else {
        flashToast('Link copied');
      }
    }

    btn.addEventListener('click', function () {
      if (btn.disabled) return;
      var origText = btn.textContent;
      btn.disabled = true;
      btn.textContent = '⏳ …';
      buildOcImage().then(function (blob) {
        if (!blob) throw new Error('no blob');
        var file = new File([blob], 'oc-champions-league.png', { type: 'image/png' });
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          return navigator.share({ files: [file], title: 'OC Champions League' });
        }
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url; a.download = 'oc-champions-league.png'; a.click();
        setTimeout(function () { URL.revokeObjectURL(url); }, 1000);
      }).catch(function (err) {
        // AbortError = user dismissed the share sheet; not a failure
        if (!err || err.name !== 'AbortError') fallbackLinkShare();
      }).finally(function () {
        btn.disabled = false;
        btn.textContent = origText;
      });
    });
  })();
</script>
