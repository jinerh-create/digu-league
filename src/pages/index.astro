---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getActiveMatch, getMatches, getActivePlayers, getTotalMatchCount, getTotalGamesCount, getPlayerForm } from '../lib/db';
import ScheduledMatches from '../components/scheduled/ScheduledMatches';
import FormChart from '../components/home/FormChart.astro';
import GoatCard from '../components/home/GoatCard.astro';
import { computeGOAT } from '../lib/goat';
import { verifySession } from '../lib/auth';

const runtime = (Astro.locals as Record<string, unknown>).runtime as
  | { env: { DB: D1Database } }
  | undefined;

let activeMatch = null;
let recentMatches: Awaited<ReturnType<typeof getMatches>> = [];
let playerCount = 0;
let matchCount = 0;
let roundsCount = 0;
let isAdmin = false;
let form: Awaited<ReturnType<typeof getPlayerForm>> = { series: [], matches: 0 };
let goat: Awaited<ReturnType<typeof computeGOAT>> = { goat: null, board: [], totalTitles: 0 };

const sessionSecret = runtime?.env?.SESSION_SECRET as string | undefined;
if (sessionSecret) {
  const s = await verifySession(Astro.request.headers.get('cookie'), sessionSecret);
  isAdmin = s.valid && s.role === 'admin';
}

if (runtime?.env?.DB) {
  try {
    // These were six serial round-trips; the page waits on the slowest, not the sum.
    const DB = runtime.env.DB;
    const [am, rm, players, mc, rc, fc, gt] = await Promise.all([
      getActiveMatch(DB),
      getMatches(DB, 5),
      getActivePlayers(DB),
      getTotalMatchCount(DB),
      getTotalGamesCount(DB),
      getPlayerForm(DB, 10, { activeOnly: true, minPlayed: 2 }),
      computeGOAT(DB),
    ]);
    goat = gt;
    activeMatch = am;
    recentMatches = rm;
    playerCount = players.length;
    matchCount = mc;
    roundsCount = rc;
    form = fc;
  } catch {}
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function nick(name: string | null | undefined, nickname: string | null | undefined) {
  return nickname || (name ?? '').split(' ')[0] || (name ?? '');
}
function side1(m: typeof recentMatches[0]) {
  const p1 = nick(m.player1_name, m.player1_nickname);
  const p2 = nick(m.team1_player2_name, m.team1_player2_nickname);
  return m.team1_player2_name ? `${p1} / ${p2}` : p1;
}
function side2(m: typeof recentMatches[0]) {
  const p1 = nick(m.player2_name, m.player2_nickname);
  const p2 = nick(m.team2_player2_name, m.team2_player2_nickname);
  return m.team2_player2_name ? `${p1} / ${p2}` : p1;
}
---

<BaseLayout title="Home" activeTab="home">
  <div class="container">
    <!-- Hero -->
    <div class="hero">
      <img src="/dl-logo-v2.png" alt="Digu League" class="hero-logo" />
      <p class="hero-sub">Digu League Tracker</p>
      <div class="hero-trophy-wrap">
        <img src="/trophy.png" alt="Digu League Trophy" class="hero-trophy" />
      </div>
    </div>

    <!-- Active Match CTA -->
    {activeMatch && (
      <a href={`/match/${activeMatch.id}`} class="active-match-card">
        <div class="active-match-label">
          <span class="live-dot"></span>
          <span class="label">Live Match</span>
        </div>
        <div class="active-match-players">
          <span>{side1(activeMatch)}</span>
          <span class="vs">vs</span>
          <span>{side2(activeMatch)}</span>
        </div>
        <span class="btn btn-primary" style="margin-top: 0.75rem">Continue Scoring &rarr;</span>
      </a>
    )}

    <!-- Quick Stats -->
    <div class="stats-strip">
      <div class="stat-pill">
        <span class="stat-value">{playerCount}</span>
        <span class="stat-label">Players</span>
      </div>
      <div class="stat-pill">
        <span class="stat-value">{matchCount}</span>
        <span class="stat-label">Matches</span>
      </div>
      <a href="/records" class="stat-pill" style="text-decoration:none;">
        <span class="stat-value">&#127942;</span>
        <span class="stat-label">Records</span>
      </a>
      <a href="/awards" class="stat-pill" style="text-decoration:none;">
        <span class="stat-value">&#127941;</span>
        <span class="stat-label">Awards</span>
      </a>
    </div>

    <!-- Greatest of All Time -->
    <GoatCard board={goat.board} totalTitles={goat.totalTitles} />

    <!-- Form Chart -->
    <FormChart series={form.series} matches={form.matches} />

    <!-- Quick Actions -->
    {!activeMatch && (
      <div class="quick-actions">
        <a href="/new-match" class="btn btn-primary btn-lg btn-block">
          &#9654; Start New Match
        </a>
      </div>
    )}

    <!-- Upcoming Fixtures -->
    <ScheduledMatches isAdmin={isAdmin} client:load />

    <!-- Recent Matches -->
    {recentMatches.length > 0 && (
      <section class="recent-section">
        <div class="section-header">
          <h2>Recent Matches</h2>
          <a href="/matches" class="see-all">See all</a>
        </div>
        <div class="match-list">
          {recentMatches.map((m) => (
            <a
              href={m.completed_at ? `/matches` : `/match/${m.id}`}
              class="match-row card home-match-card"
            >
              <div class="match-players">
                <span class={m.winner_id === m.player1_id ? 'winner' : ''}>
                  {m.winner_id === m.player1_id && <span>🏆 </span>}{side1(m)}
                </span>
                <span class="vs">vs</span>
                <span class={m.winner_id === m.player2_id ? 'winner' : ''}>
                  {m.winner_id === m.player2_id && <span>🏆 </span>}{side2(m)}
                </span>
              </div>
              <div class="match-meta">
                {m.completed_at
                  ? <span class="badge" style="background: linear-gradient(135deg, #b8922a 0%, #d4af37 50%, #e8c84a 100%); color: #1a1000; border: 1px solid #d4af37; font-weight: 800; letter-spacing: 0.04em; box-shadow: 0 2px 8px rgba(212,175,55,0.4); text-transform: uppercase; font-size: 0.6875rem;">🏆 {m.winner_id === m.player1_id ? side1(m) : side2(m)}</span>
                  : <span class="badge badge-gin">In Progress</span>
                }
                <span class="match-date">{formatDate(m.started_at)}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {recentMatches.length === 0 && playerCount === 0 && (
      <div class="empty-state">
        <p>Welcome! Add players and start your first match.</p>
        <div style="display:flex; gap: 0.75rem; justify-content: center; margin-top: 1rem; flex-wrap: wrap;">
          <a href="/players" class="btn btn-secondary">Add Players</a>
          <a href="/new-match" class="btn btn-primary">New Match</a>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 1.5rem 0 1rem;
  }

  .hero-logo {
    width: 150px;
    height: 150px;
    object-fit: cover;
    border-radius: 28px;
    margin: 0 auto 0.75rem;
    display: block;
    box-shadow:
      0 0 0 2px rgba(212,175,55,0.3),
      0 16px 48px rgba(0,0,0,0.6),
      0 0 40px rgba(212,175,55,0.2);
    
  }
  

  .hero-sub {
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .hero-trophy-wrap {
    perspective: 600px;
    margin: 0.75rem auto 0;
    width: 200px;
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-trophy {
    width: 190px;
    height: auto;
    display: block;
    transform-style: preserve-3d;
    
    filter:
      drop-shadow(0 2px 0px rgba(212,175,55,0.9))
      drop-shadow(0 6px 6px rgba(0,0,0,0.7))
      drop-shadow(0 16px 32px rgba(212,175,55,0.35))
      drop-shadow(0 32px 48px rgba(0,0,0,0.5));
  }

  @keyframes trophy-3d {
    0%   { transform: rotateY(-18deg) rotateX(6deg) translateY(0px); }
    25%  { transform: rotateY(0deg)   rotateX(3deg) translateY(-10px); }
    50%  { transform: rotateY(18deg)  rotateX(6deg) translateY(0px); }
    75%  { transform: rotateY(0deg)   rotateX(3deg) translateY(-10px); }
    100% { transform: rotateY(-18deg) rotateX(6deg) translateY(0px); }
  }

  .active-match-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 1.25rem;
    padding: 1.375rem 1.25rem;
    background: linear-gradient(160deg, #1a2240 0%, #111827 60%, #0f1620 100%);
    border: 2px solid #D4AF37;
    border-radius: var(--radius-lg);
    box-shadow:
      0 0 0 1px rgba(212,175,55,0.15),
      0 4px 24px rgba(212,175,55,0.18),
      0 8px 40px rgba(0,0,0,0.5);
    position: relative;
    overflow: hidden;
  }

  /* gold shimmer line across top */
  .active-match-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, #FFE566, #D4AF37, #FFE566, transparent);
  }

  .active-match-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.625rem;
  }

  .active-match-label .label {
    color: #D4AF37;
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--heart);
    box-shadow: 0 0 6px var(--heart);
    
  }

  
    50% { opacity: 0.4; box-shadow: none; }
  }

  .active-match-players {
    font-size: 1.2rem;
    font-weight: 800;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    color: var(--text-primary);
    letter-spacing: 0.01em;
    flex-wrap: wrap;
    justify-content: center;
  }

  .vs {
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--card-raised);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
  }

  .stats-strip {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .stat-pill {
    flex: 1;
    background: var(--card);
    border: 1.5px solid rgba(212,175,55,0.45);
    border-radius: var(--radius);
    padding: 0.875rem 0.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    box-shadow: 0 0 14px rgba(212,175,55,0.1), inset 0 1px 0 rgba(212,175,55,0.08);
    
  }
  

  .quick-actions {
    margin-bottom: 1.5rem;
  }

  .recent-section {
    margin-top: 0.25rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .see-all {
    font-size: 0.8125rem;
    color: var(--felt-light);
    font-weight: 600;
  }

  .match-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .match-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
  }

  .home-match-card {
    border: 1.5px solid rgba(212,175,55,0.45) !important;
    box-shadow: 0 0 14px rgba(212,175,55,0.1), inset 0 1px 0 rgba(212,175,55,0.08) !important;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .home-match-card:hover {
    border-color: rgba(212,175,55,0.7) !important;
    box-shadow: 0 0 24px rgba(212,175,55,0.18) !important;
  }
  .home-match-card::after {
    content: '';
    position: absolute; top: 0; left: -100%; width: 60%; height: 2px;
    background: linear-gradient(90deg, transparent, rgba(212,175,55,0.9), rgba(255,255,255,0.6), rgba(212,175,55,0.9), transparent);
    
  }
   60%{left:150%} 100%{left:150%} }

  .match-players {
    display: flex;
    align-items: center;
    gap: 0.5rem;
