---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import FutCard from '../components/home/FutCard.astro';
import { computeGOAT, type GoatRow } from '../lib/goat';

const runtime = (Astro.locals as Record<string, unknown>).runtime as { env: { DB: D1Database } } | undefined;
let board: GoatRow[] = [];
let totalTitles = 0;
if (runtime?.env?.DB) {
  try { const g = await computeGOAT(runtime.env.DB); board = g.board; totalTitles = g.totalTitles; } catch {}
}
---
<BaseLayout title="Greatest of All Time" activeTab="home">
  <div class="container">
    <div class="page-header">
      <h1>🐐 Greatest of All Time</h1>
      <p class="sub">Every player, ranked. Gold · silver · bronze for the podium, then the field. A live composite of <b>league titles</b>, <b>win rate</b>, <b>game %</b> and <b>digus</b>.</p>
    </div>

    {board.length === 0 ? (
      <div class="empty-state"><p>No completed matches yet.</p></div>
    ) : (
      <div class="goat-cards">
        {board.map(r => <FutCard r={r} rank={r.rank} big={r.rank === 1} />)}
      </div>
    )}
    <p class="goat-note">{totalTitles} monthly {totalTitles === 1 ? 'title' : 'titles'} awarded · 8+ matches to realistically top the list · updates every match.</p>
  </div>
</BaseLayout>

<style>
  .page-header .sub { color: var(--text-muted); font-size: .82rem; margin-top: .25rem; line-height: 1.5; }
  .page-header .sub b { color: var(--text-secondary); }
  .goat-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(118px, 1fr)); gap: .7rem; align-items: start; }
  /* the #1 hero card spans a touch wider on roomy screens */
  .goat-cards :global(.fut-hero) { }
  .goat-note { margin-top: 1.2rem; font-size: .72rem; color: var(--text-muted); text-align: center; }
  @media (max-width: 400px) { .goat-cards { grid-template-columns: repeat(auto-fill, minmax(104px, 1fr)); gap: .5rem; } }
</style>
